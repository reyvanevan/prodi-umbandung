---
import Layout from '../layouts/Layout.astro';
import { User, Briefcase, GraduationCap, Quote } from 'lucide-react';
import { PRODI_CONFIG } from '../config/prodi.config';

const alumni = [
  {
    name: "Amelia Rahma, S.Kom.",
    classOf: "Angkatan 2019",
    role: "Lead Software Engineer",
    company: "Gojek Tokopedia (GoTo Group)",
    quote: `Di ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}, saya diajarkan dasar pemrograman, struktur data, dan arsitektur sistem yang kuat. Ini membekali saya untuk memecahkan masalah komputasi kompleks berskala besar di industri teknologi.`,
    image: "/assets/alumni-1.png"
  },
  {
    name: "Bagus Pratama, S.Kom.",
    classOf: "Angkatan 2020",
    role: "Founder & CEO",
    company: "TechInovasi Digital (Software House)",
    quote: `Penyusunan kurikulum adaptif dan bimbingan dosen di ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort} melatih mental kewirausahaan digital saya untuk mendirikan agensi pengembangan produk digital selepas lulus.`,
    image: "/assets/alumni-2.png"
  },
  {
    name: "Risa Fitria, S.Kom.",
    classOf: "Angkatan 2019",
    role: "Data Scientist",
    company: "PT Telekomunikasi Indonesia (Telkom)",
    quote: `Fasilitas laboratorium AI dan kurikulum sains data yang mendalam di ${PRODI_CONFIG.acronym} memberikan pondasi kuat bagi saya untuk mengolah big data guna pengambilan keputusan bisnis strategis.`,
    image: "/assets/alumni-3.png"
  }
];

const sectors = [
  { name: "Software Engineering & App Development", percentage: "45%" },
  { name: "Data Science & Artificial Intelligence", percentage: "30%" },
  { name: "Network Security & Cloud Computing", percentage: "15%" },
  { name: "Pendidikan, Riset, & IT Consultant", percentage: "10%" }
];
---

<Layout title={`Alumni ${PRODI_CONFIG.acronym} | ${PRODI_CONFIG.degree} ${PRODI_CONFIG.name.id} ${PRODI_CONFIG.universityShort}`} lang="id">
  {/* Header Section */}
  <section className="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div className="max-w-7xl mx-auto px-6 lg:px-12">
      <p className="tech-tag text-mono-yellow mb-3">GRADUATES // NETWORK</p>
      <h1 className="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        Jejak Karier & Alumni
      </h1>
      <p className="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        Selamat datang di gerbang jejaring alumni {PRODI_CONFIG.acronym} {PRODI_CONFIG.universityShort}. Alumni kami tersebar secara profesional sebagai software engineer, startup founder, data scientist, network engineer, dan konsultan IT.
      </p>
    </div>
  </section>

  {/* Main Content */}
  <section className="py-20 bg-mono-cream min-h-screen">
    <div className="max-w-7xl mx-auto px-6 lg:px-12">
      
      {/* Statistics Row */}
      <div className="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-20 items-center">
        <div className="lg:col-span-5">
          <p className="tech-tag text-mono-yellow mb-2">CAREER DISTRIBUTION</p>
          <h2 className="font-serif text-3xl font-bold text-mono-black mb-6">Sebaran Sektor Industri Lulusan</h2>
          <p className="font-sans text-xs text-neutral-600 leading-relaxed mb-6">
            Berdasarkan data pelacakan alumni terbaru, lulusan prodi {PRODI_CONFIG.acronym} {PRODI_CONFIG.universityShort} memiliki fleksibilitas karier yang tinggi baik di sektor korporasi maupun merintis startup teknologi secara mandiri.
          </p>
        </div>
        <div className="lg:col-span-7 border border-mono-black bg-white p-8 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
          <div className="flex flex-col gap-5">
            {sectors.map((s, idx) => (
              <div key={idx} className="flex flex-col gap-1.5">
                <div className="flex justify-between text-xs font-sans font-bold text-mono-black">
                  <span>{s.name}</span>
                  <span>{s.percentage}</span>
                </div>
                <div className="w-full bg-neutral-100 border border-mono-black h-4 relative overflow-hidden">
                  <div className="bg-mono-yellow h-full" style={{ width: s.percentage }} />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div className="border-b border-dotted border-mono-black/20 my-16"></div>

      {/* Alumni Profiles */}
      <div className="mb-12">
        <p className="tech-tag text-mono-yellow mb-2">SUCCESS STORIES</p>
        <h2 className="font-serif text-3xl font-bold text-mono-black">Profil Alumni Berprestasi</h2>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
        {alumni.map((al, idx) => (
          <div key={idx} className="border border-mono-black bg-white p-8 hover:shadow-[6px_6px_0px_0px_var(--primary-color)] transition-all duration-300 flex flex-col justify-between">
            <div className="relative">
              <div className="absolute top-0 right-0 opacity-10">
                <Quote className="h-12 w-12 text-mono-yellow" />
              </div>
              <p className="font-sans text-xs italic text-neutral-600 leading-relaxed mb-8 pt-4">
                "{al.quote}"
              </p>
            </div>
            
            <div className="flex items-center gap-4 pt-6 border-t border-dotted border-neutral-200">
              <div className="h-10 w-10 bg-mono-yellow/25 border border-mono-black flex items-center justify-center font-serif font-bold text-mono-black text-sm shrink-0">
                {al.name.charAt(0)}
              </div>
              <div className="flex flex-col min-w-0">
                <span className="font-serif font-bold text-xs text-mono-black truncate">{al.name}</span>
                <span className="tech-tag text-[8px] text-mono-black/45 mt-0.5">{al.classOf}</span>
                <span className="font-sans text-[9px] text-neutral-500 font-bold truncate mt-1">{al.role}</span>
                <span className="font-sans text-[9px] text-mono-yellow font-bold truncate">{al.company}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
</Layout>
