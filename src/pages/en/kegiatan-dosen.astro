---
import Layout from '../../layouts/Layout.astro';
import { Calendar, MapPin, Eye } from 'lucide-react';
import { PRODI_CONFIG } from '../../config/prodi.config';

const activities = [
  {
    title: "International Textile Exhibition 'Fiber Art Dialogue' 2025",
    date: "March 12, 2025",
    location: "Kuala Lumpur, Malaysia",
    desc: `${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort} faculty representatives represent Indonesia in exhibiting large-scale fiber art installations that explore banana pseudo-stem fibers and recycled yarns in an eco-preservation dialogue.`,
    image: "/assets/kegiatan-d1.png"
  },
  {
    title: "Natural Dye Workshop for West Java Textile Artisans",
    date: "October 18, 2024",
    location: "Soreang, Bandung",
    desc: "A Public Service initiative providing technical guidance on standardization of Indigofera and caesalpinia sappan wood natural dyes to elevate local artisan weavers competitiveness.",
    image: "/assets/kegiatan-d2.png"
  },
  {
    title: "Joint Research on Natural Fiber Reinforced Composites with BRIN",
    date: "June 04, 2024",
    location: "BRIN Physics Lab, Serpong",
    desc: `A strategic research collaboration by ${PRODI_CONFIG.acronym} lecturers testing mechanical properties of chemically-modified abaca and pineapple leaf fibers for eco-friendly automotive composite parts.`,
    image: "/assets/kegiatan-d3.png"
  }
];
---

<Layout title={`Faculty Activities | ${PRODI_CONFIG.degree} ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`} lang="en">
  {/* Header Section */}
  <section className="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div className="max-w-7xl mx-auto px-6 lg:px-12">
      <p className="tech-tag text-mono-yellow mb-3">GALLERY // FACULTY ACTIVITIES</p>
      <h1 className="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        Faculty Activities & Initiatives
      </h1>
      <p className="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        Documentation of academic endeavors, professional fiber art exhibitions, applied community service, and collaborative engineering research conducted by the faculty of {PRODI_CONFIG.acronym} {PRODI_CONFIG.universityShort}.
      </p>
    </div>
  </section>

  {/* Main Grid */}
  <section className="py-20 bg-mono-cream min-h-screen">
    <div className="max-w-7xl mx-auto px-6 lg:px-12">
      <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
        {activities.map((act, idx) => (
          <div key={idx} className="border border-mono-black bg-white hover:shadow-[6px_6px_0px_0px_var(--primary-color)] transition-all duration-300 flex flex-col justify-between">
            {/* Visual Container */}
            <div className="bg-neutral-100 aspect-[4/3] border-b border-mono-black relative overflow-hidden flex items-center justify-center">
              <span className="tech-tag text-mono-black/40 text-[10px]">DOKUMENTASI D-0{idx+1}</span>
            </div>
            
            <div className="p-8 flex-1 flex flex-col justify-between">
              <div>
                <div className="flex flex-wrap gap-4 text-[10px] font-sans font-semibold text-neutral-400 mb-4">
                  <div className="flex items-center gap-1.5">
                    <Calendar className="h-3.5 w-3.5 text-mono-yellow" />
                    <span>{act.date}</span>
                  </div>
                  <div className="flex items-center gap-1.5">
                    <MapPin className="h-3.5 w-3.5 text-mono-yellow" />
                    <span>{act.location}</span>
                  </div>
                </div>
                
                <h3 className="font-serif text-lg font-bold text-mono-black mb-3 leading-snug">
                  {act.title}
                </h3>
                
                <p className="font-sans text-xs text-neutral-600 leading-relaxed mb-6">
                  {act.desc}
                </p>
              </div>

              <div className="pt-4 border-t border-dotted border-neutral-200 flex items-center justify-between">
                <span className="tech-tag text-[9px] text-mono-yellow font-bold">FACULTY / RESEARCH</span>
                <span className="flex items-center gap-1 font-sans text-[9px] font-bold text-mono-black/60">
                  <Eye className="h-3 w-3" />
                  <span>MEDIA ARCHIVE</span>
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
