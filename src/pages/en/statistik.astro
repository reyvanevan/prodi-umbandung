---
import Layout from '../../layouts/Layout.astro';
import { Users, UserCheck, Clock, BarChart3 } from 'lucide-react';
import { PRODI_CONFIG } from '../../config/prodi.config';

const yearlyMaba = [
  { year: "2021", count: 42 },
  { year: "2022", count: 45 },
  { year: "2023", count: 50 },
  { year: "2024", count: 55 },
  { year: "2025", count: 58 },
];
---

<Layout title={`Program Statistics | ${PRODI_CONFIG.degree} ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`} lang="en">
  {/* Header Section */}
  <section className="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div className="max-w-7xl mx-auto px-6 lg:px-12">
      <p className="tech-tag text-mono-yellow mb-3">DATA // STATISTICS</p>
      <h1 className="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        Academic Program Statistics
      </h1>
      <p className="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        Visualizing data trends of new student admissions, supervisor ratios, and the average duration of graduation for the {PRODI_CONFIG.degree} {PRODI_CONFIG.name.en} program at {PRODI_CONFIG.universityShort}.
      </p>
    </div>
  </section>

  {/* Main Stats Sections */}
  <section className="py-20 bg-mono-cream min-h-screen space-y-16">
    <div className="max-w-7xl mx-auto px-6 lg:px-12">
      
      {/* Grid of the three main statistics sections */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
        
        {/* Card 1: Rata-Rata Maba */}
        <div id="rata-maba" className="scroll-mt-32 border border-mono-black bg-white p-8 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex flex-col justify-between">
          <div>
            <div className="p-3 bg-mono-black text-white w-fit shadow-[2px_2px_0px_0px_var(--primary-color)] mb-6">
              <Users className="h-6 w-6" />
            </div>
            <h3 className="font-serif text-xl font-bold mb-3 text-mono-black">New Student Intake</h3>
            <p className="font-sans text-xs text-neutral-600 leading-relaxed mb-6">
              The enrollment rates of new creative students at {PRODI_CONFIG.acronym} {PRODI_CONFIG.universityShort} show a steady yearly growth, with an average of 50+ students per academic year.
            </p>
          </div>
          <div className="border-t border-dotted border-neutral-200 pt-6">
            <span className="font-serif text-4xl font-bold text-mono-black block mb-1">50.6</span>
            <span className="tech-tag text-[9px] text-mono-yellow font-bold">AVG STUDENTS / YEAR</span>
          </div>
        </div>

        {/* Card 2: Rasio Dosen */}
        <div id="rasio-dosen" className="scroll-mt-32 border border-mono-black bg-white p-8 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex flex-col justify-between">
          <div>
            <div className="p-3 bg-mono-black text-white w-fit shadow-[2px_2px_0px_0px_var(--primary-color)] mb-6">
              <UserCheck className="h-6 w-6" />
            </div>
            <h3 className="font-serif text-xl font-bold mb-3 text-mono-black">Lecturer-Student Ratio</h3>
            <p className="font-sans text-xs text-neutral-600 leading-relaxed mb-6">
              Our active lecturer-to-student ratio is highly optimal, allowing for focused and personalized supervision during intensive studio experiments.
            </p>
          </div>
          <div className="border-t border-dotted border-neutral-200 pt-6">
            <span className="font-serif text-4xl font-bold text-mono-black block mb-1">1 : 11</span>
            <span className="tech-tag text-[9px] text-mono-yellow font-bold">DIKTI STANDARD MAX 1:45</span>
          </div>
        </div>

        {/* Card 3: Rasio Masa Studi */}
        <div id="rasio-studi" className="scroll-mt-32 border border-mono-black bg-white p-8 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex flex-col justify-between">
          <div>
            <div className="p-3 bg-mono-black text-white w-fit shadow-[2px_2px_0px_0px_var(--primary-color)] mb-6">
              <Clock className="h-6 w-6" />
            </div>
            <h3 className="font-serif text-xl font-bold mb-3 text-mono-black">Study Duration Ratio</h3>
            <p className="font-sans text-xs text-neutral-600 leading-relaxed mb-6">
              More than 85% of our students complete their studies on time in 8 semesters (4 years) through well-structured Final Project mentoring.
            </p>
          </div>
          <div className="border-t border-dotted border-neutral-200 pt-6">
            <span className="font-serif text-4xl font-bold text-mono-black block mb-1">3.8 Years</span>
            <span className="tech-tag text-[9px] text-mono-yellow font-bold">AVERAGE GRADUATION TIME</span>
          </div>
        </div>

      </div>

      {/* Visual Chart Graphic */}
      <div className="border border-mono-black bg-white p-8 lg:p-12 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)]">
        <div className="flex items-center gap-3 mb-8">
          <BarChart3 className="h-5 w-5 text-mono-yellow" />
          <h4 className="font-serif text-2xl font-bold text-mono-black">New Student Admission Trends</h4>
        </div>
        
        {/* Simple Bar Chart */}
        <div className="flex flex-col gap-6">
          {yearlyMaba.map((m, idx) => (
            <div key={idx} className="flex items-center gap-4">
              <span className="font-sans font-bold text-xs text-mono-black w-12">{m.year}</span>
              <div className="flex-1 bg-neutral-100 border border-mono-black h-8 relative overflow-hidden">
                <div 
                  className="bg-mono-yellow border-r border-mono-black h-full transition-all duration-1000"
                  style={{ width: `${(m.count / 65) * 100}%` }}
                />
              </div>
              <span className="font-serif font-bold text-sm text-mono-black w-20 text-right">{m.count} Students</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</Layout>
