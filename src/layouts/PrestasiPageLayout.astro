---
import Layout from './Layout.astro';
import { Award, Trophy, Bookmark, Sparkles } from 'lucide-react';
import { PRODI_CONFIG } from '../config/prodi.config';
import { getPrestasi } from '../lib/supabase/db';

interface Props {
  lang: 'id' | 'en';
}

const { lang } = Astro.props;

const title = lang === 'en'
  ? `Achievements & Recognition | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`
  : `Prestasi & Penghargaan | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`;

const heading = lang === 'en' ? 'Program & Student Achievements' : 'Galeri Prestasi & Penghargaan';

const description = lang === 'en'
  ? `Celebrating academic excellences, research breakthroughs, national hackathon podiums, and professional accolades of our students and faculty members.`
  : `Apresiasi atas pencapaian akademik terbaik, hibah riset, podium kejuaraan hackathon nasional, dan pengakuan profesional mahasiswa serta dosen.`;

// ── Fallback static data ────────────────────────────────────────────────────
type PrestasiItem = { title: string; year: string; desc: string; image: string | null; host: string | null; competitor: string | null };

const fallbackProdi: PrestasiItem[] = [
  {
    title: lang === 'en' ? "National BAN-PT 'Baik Sekali' Accreditation" : "Akreditasi Nasional BAN-PT 'Baik Sekali'",
    year: '2024',
    desc: lang === 'en'
      ? "Achieved the superior 'Baik Sekali' standard for laboratory facilities and curriculum alignment in Halal Food Technology."
      : "Berhasil memperoleh predikat akreditasi 'Baik Sekali' atas standar sarana laboratorium dan kesesuaian kurikulum Teknologi Pangan Halal.",
    image: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=600&auto=format&fit=crop',
    host: null, competitor: null
  },
  {
    title: lang === 'en' ? 'Halal Food Lab ISO 17025 Certification' : 'Sertifikasi ISO 17025 Laboratorium Pangan Halal',
    year: '2023',
    desc: lang === 'en'
      ? 'Officially certified laboratory for testing food safety, nutrition, and chemical composition of local agricultural materials.'
      : 'Laboratorium resmi terakreditasi untuk pengujian keamanan pangan, nutrisi, dan komposisi kimia bahan pertanian lokal.',
    image: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?q=80&w=600&auto=format&fit=crop',
    host: null, competitor: null
  },
  {
    title: lang === 'en' ? 'Kemendikbud Research Grant on Circular Biorefinery' : 'Penerima Hibah Riset Kemendikbudristek Biorefinery Sirkular',
    year: '2024',
    desc: lang === 'en'
      ? 'Received national funding for utilizing local agricultural waste into functional food packaging.'
      : 'Memperoleh pendanaan riset nasional untuk pemanfaatan limbah pertanian lokal menjadi kemasan pangan fungsional.',
    image: 'https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?q=80&w=600&auto=format&fit=crop',
    host: null, competitor: null
  }
];

const fallbackMahasiswa: PrestasiItem[] = [
  {
    title: lang === 'en' ? '1st Place Gold Medal // National Food Innovation Competition' : 'Juara I Medali Emas // Kompetisi Inovasi Pangan Nasional',
    year: '2024',
    host: lang === 'en' ? 'Ministry of Agriculture (Kementan)' : 'Kementerian Pertanian (Kementan)',
    competitor: lang === 'en' ? 'Aditya Pratama & Team' : 'Aditya Pratama & Tim',
    desc: lang === 'en'
      ? 'Developed a nutrient-dense functional biscuit from local Hanjeli seeds and red kidney beans.'
      : 'Mengembangkan produk biskuit fungsional padat gizi berbasis tepung hanjeli dan kacang merah lokal.',
    image: 'https://images.unsplash.com/photo-1509440159596-0249088772ff?q=80&w=600&auto=format&fit=crop'
  },
  {
    title: lang === 'en' ? 'Best Functional Product // World Food Day Exhibition' : 'Produk Fungsional Terbaik // Pameran Hari Pangan Sedunia',
    year: '2023',
    host: lang === 'en' ? 'PATPI' : 'Perhimpunan Ahli Teknologi Pangan Indonesia (PATPI)',
    competitor: lang === 'en' ? 'Siti Rahma & Team' : 'Siti Rahma & Tim',
    desc: lang === 'en'
      ? 'Created edible active packaging films using cassava starch and mangosteen peel extract.'
      : 'Membuat kemasan aktif edible film ramah lingkungan berbahan pati tapioka dan ekstrak kulit manggis.',
    image: 'https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=600&auto=format&fit=crop'
  },
  {
    title: lang === 'en' ? 'Winner of Young Halal Technopreneur Award' : 'Pemenang Penghargaan Wirausaha Halal Muda',
    year: '2024',
    host: 'Halal Science Center & MUI',
    competitor: 'Rifqi Fauzan',
    desc: lang === 'en'
      ? 'Recognized for developing a startup model focused on scale-up production of local organic condiments.'
      : 'Penghargaan atas perancangan model bisnis dan sistem produksi skala industri bumbu organik lokal.',
    image: 'https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?q=80&w=600&auto=format&fit=crop'
  }
];

// ── Fetch from DB, fall back to static ──────────────────────────────────────
const dbPrestasi = await getPrestasi();
let prodiAchievements: PrestasiItem[] = fallbackProdi;
let studentWins: PrestasiItem[] = fallbackMahasiswa;

if (dbPrestasi && dbPrestasi.length > 0) {
  const mapItem = (p: typeof dbPrestasi[0]): PrestasiItem => ({
    title: lang === 'en' ? (p.title_en || p.title) : p.title,
    year: p.year,
    desc: lang === 'en' ? (p.desc_en || p.desc) : p.desc,
    image: p.image_url,
    host: lang === 'en' ? (p.host_en || p.host) : p.host,
    competitor: p.competitor
  });
  prodiAchievements = dbPrestasi.filter(p => p.type === 'prodi').map(mapItem);
  studentWins = dbPrestasi.filter(p => p.type === 'mahasiswa').map(mapItem);
}

// ── (unused compat block kept for reference) ─────────────────────────────────
---



<Layout title={title} lang={lang}>
  {/* Header Section */}
  <section class="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <p class="tech-tag text-mono-yellow mb-3 font-sans">GALLERY // AWARDS</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        {heading}
      </h1>
      <p class="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  {/* Main Achievements Display */}
  <section class="py-20 bg-mono-cream min-h-screen space-y-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      
      {/* 1. Department/Institutional Awards */}
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <Bookmark class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Institutional Accreditations & Milestones' : 'Penghargaan & Akreditasi Program Studi'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {prodiAchievements.map((pa) => (
            <div class="border border-mono-black bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex flex-col justify-between hover:shadow-[6px_6px_0px_0px_var(--primary-color)] transition-all group overflow-hidden">
              <div>
                <div class="h-48 overflow-hidden border-b border-mono-black relative bg-neutral-100">
                  <img 
                    src={pa.image} 
                    alt={pa.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                  <div class="absolute top-4 left-4 bg-mono-black text-white text-[9px] font-sans font-bold px-3 py-1 uppercase tracking-wider border border-white/20 shadow-[2px_2px_0px_0px_rgba(255,255,255,0.2)]">
                    {pa.year}
                  </div>
                </div>
                <div class="p-8">
                  <span class="tech-tag text-[9px] text-mono-yellow font-bold block mb-3">INSTITUTIONAL ACHIEVEMENT</span>
                  <h3 class="font-serif text-lg font-bold text-mono-black mb-3 leading-snug">{pa.title}</h3>
                  <p class="font-sans text-xs text-neutral-600 leading-relaxed">
                    {pa.desc}
                  </p>
                </div>
              </div>
              <div class="px-8 pb-8">
                <div class="border-t border-dashed border-neutral-200 pt-4 flex items-center gap-2 text-mono-black/45">
                  <Award class="h-4.5 w-4.5" />
                  <span class="font-serif text-[10px] uppercase font-bold tracking-wider">{PRODI_CONFIG.acronym} {PRODI_CONFIG.universityShort}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* 2. Student Competition Success Grid */}
      <div>
        <div class="flex items-center gap-3 mb-8">
          <Trophy class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Student Competition Honor Roll' : 'Prestasi Kompetisi & Kejuaraan Mahasiswa'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {studentWins.map((sw) => (
            <div class="border border-mono-black bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex flex-col justify-between hover:shadow-[6px_6px_0px_0px_var(--primary-color)] transition-all group overflow-hidden">
              <div>
                <div class="h-48 overflow-hidden border-b border-mono-black relative bg-neutral-100">
                  <img 
                    src={sw.image} 
                    alt={sw.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                  <div class="absolute top-4 left-4 bg-mono-black text-white text-[9px] font-sans font-bold px-3 py-1 uppercase tracking-wider border border-white/20 shadow-[2px_2px_0px_0px_rgba(255,255,255,0.2)]">
                    {sw.year}
                  </div>
                </div>
                <div class="p-8">
                  <span class="tech-tag text-[9px] text-mono-yellow font-bold block mb-2">COMPETITION WINNER</span>
                  <h3 class="font-serif text-lg font-bold text-mono-black mb-1 leading-snug">{sw.title}</h3>
                  <span class="tech-tag text-[8px] text-neutral-500 block mb-4">{sw.competitor}</span>
                  <p class="font-sans text-xs text-neutral-600 leading-relaxed">
                    {sw.desc}
                  </p>
                </div>
              </div>
              <div class="px-8 pb-8">
                <div class="border-t border-dotted border-neutral-200 pt-4 flex items-center justify-between text-neutral-500 font-sans text-[9px]">
                  <span class="font-bold uppercase tracking-wider">{sw.host}</span>
                  <Sparkles class="h-3.5 w-3.5 text-mono-yellow" />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</Layout>
