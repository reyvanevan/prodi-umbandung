---
import Layout from './Layout.astro';
import { BookOpen, GraduationCap, Award, Compass } from 'lucide-react';
import { PRODI_CONFIG } from '../config/prodi.config';
import { getSiteContent, getKurikulumCourses, getKurikulumPlos, getKurikulumProfiles } from '../lib/supabase/db';

interface Props {
  lang: 'id' | 'en';
}

const { lang } = Astro.props;

// Fetch database site content
const siteContent = await getSiteContent();
const contentMap = (siteContent || []).reduce((acc, curr) => {
  acc[curr.key] = lang === 'en' ? (curr.value_en || curr.value) : curr.value;
  return acc;
}, {} as Record<string, string>);

const title = lang === 'en'
  ? `Curriculum & Academic Structure | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`
  : `Kurikulum & Akademik | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`;

const heading = lang === 'en' ? 'Academic Program Curriculum' : 'Kurikulum & Capaian Pembelajaran';

const defaultDescription = lang === 'en'
  ? `Explore our modern, adaptive curriculum structured around international computing standards (ACM/IEEE), industry certifications, and MBKM learning path designs.`
  : `Pelajari kurikulum adaptif kami yang disusun berdasarkan standar komputasi internasional (ACM/IEEE), sertifikasi profesi industri, serta skema Merdeka Belajar Kampus Merdeka (MBKM).`;

const description = contentMap['kurikulum_description'] || defaultDescription;

// 1. Graduate Profiles (Fallbacks)
const fallbackProfiles = lang === 'en' ? [
  {
    title: "Food Product Developer / R&D Specialist",
    desc: "Professionals who design, formulate, and optimize safe, nutritious, and halal food products using local Nusantara agricultural resources."
  },
  {
    title: "Quality Assurance & QC Specialist",
    desc: "Experts managing food safety systems (HACCP, ISO 22000, Halal Certification) and analyzing food chemical and microbiological quality."
  },
  {
    title: "Food Process & Production Engineer",
    desc: "Specialists managing food manufacturing operations, industrial processing equipment, and sustainable circular biorefinery systems."
  },
  {
    title: "Halal Food Auditor & Consultant",
    desc: "Advisors evaluating halal compliance in supply chains, auditing food production processes, and consulting for certification."
  }
] : [
  {
    title: "Food Product Developer / R&D Specialist",
    desc: "Profesional yang merancang, memformulasikan, dan mengoptimalkan produk pangan baru yang aman, bergizi, dan halal berbasis komoditas lokal."
  },
  {
    title: "Quality Assurance & QC Specialist",
    desc: "Tenaga ahli yang mengelola sistem keamanan pangan (HACCP, ISO 22000, Sertifikasi Halal) serta melakukan analisis kimia & mikrobiologi pangan."
  },
  {
    title: "Food Process & Production Engineer",
    desc: "Spesialis pengelola operasional pabrik pengolahan pangan, mesin pengolahan industri, dan sistem biorefinery sirkular nirlimbah."
  },
  {
    title: "Halal Food Auditor & Konsultan",
    desc: "Konsultan dan auditor yang mengevaluasi kepatuhan halal rantai pasok, melakukan audit proses produksi pangan, serta bimbingan sertifikasi."
  }
];

const dbProfiles = await getKurikulumProfiles();
const profiles = (dbProfiles && dbProfiles.length > 0)
  ? dbProfiles.map(p => ({
      title: lang === 'en' ? (p.title_en || p.title) : p.title,
      desc: lang === 'en' ? (p.desc_en || p.desc) : p.desc
    }))
  : fallbackProfiles;

// 2. Program Learning Outcomes (PLO/CPL) (Fallbacks)
const fallbackPlos = lang === 'en' ? [
  { code: "CPL-01", type: "Ethics", text: "Apply professional ethics, Islamic principles, and halal food regulatory compliance in food supply chains." },
  { code: "CPL-02", type: "Core Knowledge", text: "Demonstrate solid knowledge of food science principles (chemistry, microbiology, nutrition) and food engineering." },
  { code: "CPL-03", type: "Quality & Safety", text: "Design and manage food quality assurance and safety systems (HACCP, Halal, GMP, SSOP)." },
  { code: "CPL-04", type: "Innovation", text: "Formulate innovative functional and sustainable food products based on local agricultural resources." }
] : [
  { code: "CPL-01", type: "Etika", text: "Menerapkan etika profesi, nilai Keislaman, serta kepatuhan regulasi pangan halal dalam rantai pasok pangan." },
  { code: "CPL-02", type: "Pengetahuan", text: "Menguasai prinsip sains pangan (kimia, mikrobiologi, gizi) serta teknologi rekayasa proses pengolahan pangan." },
  { code: "CPL-03", type: "Mutu & Keamanan", text: "Merancang dan mengelola sistem penjaminan mutu serta keamanan pangan (HACCP, Halal, GMP, SSOP)." },
  { code: "CPL-04", type: "Inovasi", text: "Memformulasikan produk pangan baru yang fungsional dan berkelanjutan berbasis potensi komoditas lokal." }
];

const dbPlos = await getKurikulumPlos();
const plos = (dbPlos && dbPlos.length > 0)
  ? dbPlos.map(p => ({
      code: p.code,
      type: lang === 'en' ? (p.type_en || p.type) : p.type,
      text: lang === 'en' ? (p.text_en || p.text) : p.text
    }))
  : fallbackPlos;

// 3. Curriculum Semesters Data (Fallbacks)
const fallbackSemesters = [
  {
    sem: "I",
    courses: [
      { name_en: "Introduction to Food Technology", name_id: "Pengantar Teknologi Pangan", credits: 3 },
      { name_en: "General Chemistry", name_id: "Kimia Dasar", credits: 3 },
      { name_en: "General Biology", name_id: "Biologi Umum", credits: 3 },
      { name_en: "Islamic Studies I", name_id: "Studi Islam I", credits: 2 },
      { name_en: "English Language I", name_id: "Bahasa Inggris I", credits: 2 },
      { name_en: "Calculus", name_id: "Kalkulus", credits: 3 },
      { name_en: "Introduction to Entrepreneurship", name_id: "Pengantar Kewirausahaan", credits: 2 }
    ]
  },
  {
    sem: "II",
    courses: [
      { name_en: "Food Chemistry I", name_id: "Kimia Pangan I", credits: 3 },
      { name_en: "General Microbiology", name_id: "Mikrobiologi Umum", credits: 3 },
      { name_en: "General Physics", name_id: "Fisika Dasar", credits: 3 },
      { name_en: "Engineering Mathematics", name_id: "Matematika Teknik", credits: 3 },
      { name_en: "Islamic Studies II", name_id: "Studi Islam II", credits: 2 },
      { name_en: "Civic Education", name_id: "Pendidikan Kewarganegaraan", credits: 2 },
      { name_en: "Unit Operations in Food Industry", name_id: "Satuan Operasi Industri Pangan", credits: 3 }
    ]
  },
  {
    sem: "III",
    courses: [
      { name_en: "Food Chemistry II", name_id: "Kimia Pangan II", credits: 3 },
      { name_en: "Food Microbiology", name_id: "Mikrobiologi Pangan", credits: 3 },
      { name_en: "Food Biochemistry", name_id: "Biokimia Pangan", credits: 3 },
      { name_en: "Food Analysis", name_id: "Analisis Pangan", credits: 4 },
      { name_en: "Food Processing Machinery", name_id: "Alat & Mesin Pengolahan Pangan", credits: 3 },
      { name_en: "Islamic Studies III", name_id: "Studi Islam III", credits: 2 }
    ]
  },
  {
    sem: "IV",
    courses: [
      { name_en: "Food Safety & Sanitation", name_id: "Keamanan Pangan & Sanitasi", credits: 3 },
      { name_en: "Nusantara Food Processing Technology", name_id: "Teknologi Pengolahan Pangan Nusantara", credits: 4 },
      { name_en: "Sensory Evaluation", name_id: "Evaluasi Sensoris", credits: 3 },
      { name_en: "Food Regulations & Law", name_id: "Peraturan & Perundang-undangan Pangan", credits: 2 },
      { name_en: "Thermodynamics & Heat Transfer", name_id: "Termodinamika & Perpindahan Panas", credits: 3 },
      { name_en: "Statistics for Food Industry", name_id: "Statistika Industri Pangan", credits: 3 }
    ]
  },
  {
    sem: "V",
    courses: [
      { name_en: "Postharvest Technology & Physiology", name_id: "Fisiologi & Teknologi Pascapanen", credits: 3 },
      { name_en: "Food Packaging & Storage", name_id: "Teknologi Pengemasan & Penyimpanan", credits: 3 },
      { name_en: "Halal Product Assurance System", name_id: "Sistem Jaminan Produk Halal", credits: 3 },
      { name_en: "Nutrition & Health", name_id: "Gizi dan Kesehatan", credits: 3 },
      { name_en: "Elective Course I", name_id: "Mata Kuliah Pilihan I", credits: 3 },
      { name_en: "Islamic Studies IV", name_id: "Studi Islam IV", credits: 2 }
    ]
  },
  {
    sem: "VI",
    courses: [
      { name_en: "Research Methodology", name_id: "Metodologi Penelitian", credits: 2 },
      { name_en: "Food Factory Design", name_id: "Desain Pabrik Pangan", credits: 3 },
      { name_en: "Industrial Internship (MBKM)", name_id: "Magang Industri Pangan (MBKM)", credits: 6 },
      { name_en: "Elective Course II", name_id: "Mata Kuliah Pilihan II", credits: 3 },
      { name_en: "Elective Course III", name_id: "Mata Kuliah Pilihan III", credits: 3 }
    ]
  },
  {
    sem: "VII",
    courses: [
      { name_en: "Food Technopreneurship", name_id: "Wirausaha Mandiri Pangan", credits: 2 },
      { name_en: "Food Professional Ethics", name_id: "Etika Profesi Teknologi Pangan", credits: 2 },
      { name_en: "Thesis Proposal Seminar", name_id: "Seminar Proposal Tugas Akhir", credits: 2 },
      { name_en: "Elective Course IV", name_id: "Mata Kuliah Pilihan IV", credits: 3 },
      { name_en: "Elective Course V", name_id: "Mata Kuliah Pilihan V", credits: 3 }
    ]
  },
  {
    sem: "VIII",
    courses: [
      { name_en: "Final Thesis & Defense", name_id: "Tugas Akhir / Skripsi", credits: 6 }
    ]
  }
];

const dbCourses = await getKurikulumCourses();
let semesters = fallbackSemesters;
if (dbCourses && dbCourses.length > 0) {
  const semOrder = ["I", "II", "III", "IV", "V", "VI", "VII", "VIII"];
  const grouped: Record<string, typeof dbCourses> = {};
  semOrder.forEach(s => {
    grouped[s] = [];
  });
  
  dbCourses.forEach(c => {
    const s = c.semester;
    if (grouped[s]) {
      grouped[s].push(c);
    } else {
      grouped[s] = [c];
    }
  });
  
  semesters = semOrder.map(s => {
    const sortedCourses = (grouped[s] || []).sort((a, b) => a.sort_order - b.sort_order);
    return {
      sem: s,
      courses: sortedCourses.map(c => ({
        name_en: c.name_en || c.name,
        name_id: c.name,
        credits: c.credits
      }))
    };
  });
}

const internshipTitle = lang === 'en' ? 'MBKM & Internship Framework' : 'Skema Magang Industri & MBKM';
const defaultInternshipDesc = lang === 'en'
  ? "Our students are eligible to convert real-world industrial experiences into up to 20 academic credits under the Kemendikbud MBKM schema, collaborating with national food companies, laboratories, and halal certification agencies."
  : "Mahasiswa kami difasilitasi untuk mengkonversikan pengalaman kerja lapangan / magang industri riil hingga 20 SKS akademik di bawah skema MBKM Kemendikbud, bermitra dengan industri pangan nasional, BPOM, dan LPPOM MUI.";
const internshipDesc = contentMap['kurikulum_internship_desc'] || defaultInternshipDesc;
---

<Layout title={title} lang={lang}>
  {/* Header Section */}
  <section class="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <p class="tech-tag text-mono-yellow mb-3">ACADEMICS // CURRICULUM</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        {heading}
      </h1>
      <p class="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  {/* Main Content Area */}
  <section class="py-20 bg-mono-cream min-h-screen space-y-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      
      {/* SECTION 1: GRADUATE PROFILES */}
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <GraduationCap class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Graduate Career Profiles' : 'Profil Lulusan Utama'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {profiles.map((p, idx) => (
            <div class="border border-mono-black bg-white p-6 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] hover:shadow-[5px_5px_0px_0px_var(--primary-color)] transition-all">
              <span class="tech-tag text-[9px] text-mono-yellow font-bold block mb-3">PROFILE 0{idx+1}</span>
              <h3 class="font-serif text-base font-bold text-mono-black mb-3">{p.title}</h3>
              <p class="font-sans text-xs text-neutral-600 leading-relaxed">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>

      {/* SECTION 2: PROGRAM LEARNING OUTCOMES */}
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <Award class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Program Learning Outcomes (PLO)' : 'Capaian Pembelajaran Lulusan (CPL)'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {plos.map((p) => (
            <div class="border border-mono-black bg-white p-6 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] flex items-start gap-4">
              <span class="tech-tag text-[9px] bg-mono-black text-white px-2 py-0.5 mt-0.5 shrink-0">{p.code}</span>
              <div>
                <span class="font-serif text-[11px] font-bold text-mono-yellow tracking-wider block mb-1 uppercase">{p.type}</span>
                <p class="font-sans text-xs text-neutral-600 leading-relaxed">{p.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* SECTION 3: CURRICULUM SEMESTERS LIST */}
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <BookOpen class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Course Curriculum Structure (144 Credits)' : 'Struktur Kurikulum & Sebaran Mata Kuliah (144 SKS)'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {semesters.map((s) => (
            <div class="border border-mono-black bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] overflow-hidden">
              <div class="bg-mono-black text-white px-6 py-3.5 flex justify-between items-center border-b border-mono-black">
                <h3 class="font-serif text-base font-bold tracking-wider">
                  {lang === 'en' ? `SEMESTER ${s.sem}` : `SEMESTER ${s.sem}`}
                </h3>
                <span class="tech-tag text-[9px] text-mono-yellow">
                  {s.courses.reduce((acc, c) => acc + c.credits, 0)} {lang === 'en' ? 'CREDITS' : 'SKS'}
                </span>
              </div>
              <div class="divide-y divide-neutral-100 font-sans">
                {s.courses.map((c) => (
                  <div class="px-6 py-4 flex justify-between items-center gap-4 hover:bg-neutral-50 transition-colors">
                    <span class="text-xs font-bold text-mono-black leading-tight">
                      {lang === 'en' ? c.name_en : c.name_id}
                    </span>
                    <span class="tech-tag text-[9px] bg-neutral-100 text-neutral-500 border border-neutral-200 px-2 py-0.5 shrink-0">
                      {c.credits} SKS
                    </span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* SECTION 4: INTERNSHIP FRAMEWORK */}
      <div class="border border-mono-black bg-white p-8 lg:p-12 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-5">
          <Compass class="h-32 w-32 text-mono-yellow" />
        </div>
        <p class="tech-tag text-mono-yellow mb-2">EXPERIENTIAL LEARNING</p>
        <h3 class="font-serif text-2xl font-bold text-mono-black mb-4">{internshipTitle}</h3>
        <p class="font-sans text-xs text-neutral-600 leading-relaxed max-w-4xl mb-6">
          {internshipDesc}
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="tech-tag text-[8px] border border-mono-black/15 bg-neutral-50 text-neutral-600 px-3 py-1 font-bold">STUDY EXCHANGE // PERTUKARAN PELAJAR</span>
          <span class="tech-tag text-[8px] border border-mono-black/15 bg-neutral-50 text-neutral-600 px-3 py-1 font-bold">CERTIFIED INTERNSHIP // MAGANG INDUSTRI MSIB</span>
          <span class="tech-tag text-[8px] border border-mono-black/15 bg-neutral-50 text-neutral-600 px-3 py-1 font-bold">COMMUNITY DEVELOPMENT // KKN TEMATIK</span>
        </div>
      </div>

    </div>
  </section>
</Layout>
