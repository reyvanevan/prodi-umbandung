---
import Layout from './Layout.astro';
import { BookOpen, GraduationCap, Award, Compass } from 'lucide-react';
import { PRODI_CONFIG } from '../config/prodi.config';
import { getSiteContent } from '../lib/supabase/db';

interface Props {
  lang: 'id' | 'en';
}

const { lang } = Astro.props;

// Fetch database site content
const siteContent = await getSiteContent();
const contentMap = (siteContent || []).reduce((acc, curr) => {
  acc[curr.key] = lang === 'en' ? (curr.value_en || curr.value) : curr.value;
  return acc;
}, {} as Record<string, string>);

const title = lang === 'en'
  ? `Curriculum & Academic Structure | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`
  : `Kurikulum & Akademik | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`;

const heading = lang === 'en' ? 'Academic Program Curriculum' : 'Kurikulum & Capaian Pembelajaran';

const defaultDescription = lang === 'en'
  ? `Explore our modern, adaptive curriculum structured around international computing standards (ACM/IEEE), industry certifications, and MBKM learning path designs.`
  : `Pelajari kurikulum adaptif kami yang disusun berdasarkan standar komputasi internasional (ACM/IEEE), sertifikasi profesi industri, serta skema Merdeka Belajar Kampus Merdeka (MBKM).`;

const description = contentMap['kurikulum_description'] || defaultDescription;

// 1. Graduate Profiles
const profiles = lang === 'en' ? [
  {
    title: "Software Engineer / Developer",
    desc: "Professionals who design, implement, and maintain complex software architectures, web applications, mobile services, and secure backend platforms."
  },
  {
    title: "Cloud DevOps Specialist",
    desc: "Experts managing secure continuous integration pipelines, container deployments, microservices orchestration, and resilient cloud infrastructures."
  },
  {
    title: "Data & AI Systems Developer",
    desc: "Specialists crafting intelligence layers, parsing large datasets, building machine learning models, and automating analytics workflows."
  },
  {
    title: "IT Consultant & Solution Architect",
    desc: "Advisors translating business requisites into technical software designs, evaluating digital system feasibility, and directing tech projects."
  }
] : [
  {
    title: "Software Engineer / Developer",
    desc: "Profesional yang merancang, mengimplementasikan, dan memelihara arsitektur perangkat lunak kompleks, aplikasi web, layanan mobile, dan platform backend."
  },
  {
    title: "Cloud DevOps Specialist",
    desc: "Tenaga ahli yang mengelola pipeline integrasi berkelanjutan (CI/CD), penyebaran kontainer, orkestrasi microservices, dan infrastruktur cloud yang andal."
  },
  {
    title: "Data & AI Systems Developer",
    desc: "Spesialis yang membangun lapisan kecerdasan buatan, mengolah dataset skala besar, melatih model machine learning, dan mengotomatisasi analisis data."
  },
  {
    title: "Konsultan IT & Solution Architect",
    desc: "Konsultan yang menerjemahkan kebutuhan bisnis menjadi rancangan teknis perangkat lunak, menilai kelayakan sistem digital, dan memimpin proyek teknologi."
  }
];

// 2. Program Learning Outcomes (PLO/CPL)
const plos = lang === 'en' ? [
  { code: "CPL-01", type: "Ethics", text: "Apply professional ethics, Islamic principles, and legal accountability in software engineering practices." },
  { code: "CPL-02", type: "Core Knowledge", text: "Demonstrate solid knowledge of programming systems, algorithms, computing networks, and databases." },
  { code: "CPL-03", type: "Engineering", text: "Design, build, and test software configurations using modern DevOps pipelines and engineering standards." },
  { code: "CPL-04", type: "Innovation", text: "Formulate innovative digital solutions to societal problems through research, entrepreneurship, and collaborative projects." }
] : [
  { code: "CPL-01", type: "Etika", text: "Menerapkan etika profesional, nilai-nilai Keislaman, serta tanggung jawab hukum dalam praktik rekayasa perangkat lunak." },
  { code: "CPL-02", type: "Pengetahuan", text: "Menunjukkan pemahaman yang kokoh tentang sistem pemrograman, algoritma, jaringan komputer, dan basis data." },
  { code: "CPL-03", type: "Rekayasa", text: "Merancang, membangun, dan menguji konfigurasi perangkat lunak dengan standar DevOps modern dan teknik rekayasa." },
  { code: "CPL-04", type: "Inovasi", text: "Merumuskan solusi digital inovatif atas masalah di masyarakat melalui riset ilmiah, kewirausahaan, dan kerja kelompok." }
];

// 3. Curriculum Semesters Data
const semesters = [
  {
    sem: "I",
    courses: [
      { name_en: "Introduction to Information Technology", name_id: "Pengantar Teknologi Informasi", credits: 3 },
      { name_en: "Basic Programming", name_id: "Pemrograman Dasar", credits: 4 },
      { name_en: "Calculus", name_id: "Kalkulus", credits: 3 },
      { name_en: "Islamic Studies I", name_id: "Studi Islam I", credits: 2 },
      { name_en: "English Language I", name_id: "Bahasa Inggris I", credits: 2 },
      { name_en: "Linear Algebra", name_id: "Aljabar Linier", credits: 3 }
    ]
  },
  {
    sem: "II",
    courses: [
      { name_en: "Object-Oriented Programming", name_id: "Pemrograman Berorientasi Objek", credits: 4 },
      { name_en: "Discrete Mathematics", name_id: "Matematika Diskrit", credits: 3 },
      { name_en: "Data Structures & Algorithms", name_id: "Struktur Data & Algoritma", credits: 4 },
      { name_en: "Requirements Engineering", name_id: "Rekayasa Kebutuhan Perangkat Lunak", credits: 3 },
      { name_en: "Islamic Studies II", name_id: "Studi Islam II", credits: 2 },
      { name_en: "Civic Education", name_id: "Pendidikan Kewarganegaraan", credits: 2 }
    ]
  },
  {
    sem: "III",
    courses: [
      { name_en: "Database Systems", name_id: "Sistem Basis Data", credits: 4 },
      { name_en: "Web Application Development", name_id: "Pemrograman Web", credits: 4 },
      { name_en: "Software Architecture & Design", name_id: "Arsitektur & Desain Perangkat Lunak", credits: 3 },
      { name_en: "Human-Computer Interaction", name_id: "Interaksi Manusia & Komputer", credits: 3 },
      { name_en: "Computer Networks", name_id: "Jaringan Komputer", credits: 3 },
      { name_en: "Islamic Studies III", name_id: "Studi Islam III", credits: 2 }
    ]
  },
  {
    sem: "IV",
    courses: [
      { name_en: "Software Testing & QA", name_id: "Pengujian & Penjaminan Mutu Software", credits: 3 },
      { name_en: "Operating Systems", name_id: "Sistem Operasi", credits: 3 },
      { name_en: "Advanced Web Development", name_id: "Pemrograman Web Lanjut", credits: 4 },
      { name_en: "Cybersecurity Fundamentals", name_id: "Keamanan Siber Dasar", credits: 3 },
      { name_en: "Algorithm Analysis & Design", name_id: "Desain & Analisis Algoritma", credits: 3 },
      { name_en: "Statistics & Probability", name_id: "Statistika & Probabilitas", credits: 3 }
    ]
  },
  {
    sem: "V",
    courses: [
      { name_en: "Cloud Computing Systems", name_id: "Sistem Komputasi Awan", credits: 3 },
      { name_en: "Mobile Application Engineering", name_id: "Pemrograman Perangkat Bergerak", credits: 4 },
      { name_en: "Artificial Intelligence Foundations", name_id: "Kecerdasan Buatan Dasar", credits: 3 },
      { name_en: "Software Project Management", name_id: "Manajemen Proyek Perangkat Lunak", credits: 3 },
      { name_en: "Elective Course I", name_id: "Mata Kuliah Pilihan I", credits: 3 },
      { name_en: "Islamic Studies IV", name_id: "Studi Islam IV", credits: 2 }
    ]
  },
  {
    sem: "VI",
    courses: [
      { name_en: "Research Methodology", name_id: "Metodologi Penelitian", credits: 2 },
      { name_en: "Collaborative Software Engineering", name_id: "Rekayasa Perangkat Lunak Kolaboratif", credits: 3 },
      { name_en: "Industrial Internship (MBKM)", name_id: "Magang Industri (MBKM)", credits: 6 },
      { name_en: "Elective Course II", name_id: "Mata Kuliah Pilihan II", credits: 3 },
      { name_en: "Elective Course III", name_id: "Mata Kuliah Pilihan III", credits: 3 }
    ]
  },
  {
    sem: "VII",
    courses: [
      { name_en: "Technopreneurship", name_id: "Kewirausahaan Teknologi", credits: 2 },
      { name_en: "IT Professional Ethics", name_id: "Etika Profesi IT", credits: 2 },
      { name_en: "Thesis Proposal Seminar", name_id: "Seminar Proposal Tugas Akhir", credits: 2 },
      { name_en: "Elective Course IV", name_id: "Mata Kuliah Pilihan IV", credits: 3 },
      { name_en: "Elective Course V", name_id: "Mata Kuliah Pilihan V", credits: 3 }
    ]
  },
  {
    sem: "VIII",
    courses: [
      { name_en: "Final Thesis & Defense", name_id: "Tugas Akhir / Skripsi", credits: 6 }
    ]
  }
];

const internshipTitle = lang === 'en' ? 'MBKM & Internship Framework' : 'Skema Magang Industri & MBKM';
const defaultInternshipDesc = lang === 'en'
  ? "Our students are eligible to convert real-world industrial experiences into up to 20 academic credits under the Kemendikbud MBKM schema, collaborating with global and national technology enterprises."
  : "Mahasiswa kami difasilitasi untuk mengkonversikan pengalaman kerja lapangan / magang industri riil hingga 20 SKS akademik di bawah skema MBKM Kemendikbud, bermitra dengan startup dan BUMN teknologi terkemuka.";
const internshipDesc = contentMap['kurikulum_internship_desc'] || defaultInternshipDesc;
---

<Layout title={title} lang={lang}>
  {/* Header Section */}
  <section class="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <p class="tech-tag text-mono-yellow mb-3">ACADEMICS // CURRICULUM</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        {heading}
      </h1>
      <p class="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  {/* Main Content Area */}
  <section class="py-20 bg-mono-cream min-h-screen space-y-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      
      {/* SECTION 1: GRADUATE PROFILES */}
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <GraduationCap class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Graduate Career Profiles' : 'Profil Lulusan Utama'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {profiles.map((p, idx) => (
            <div class="border border-mono-black bg-white p-6 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] hover:shadow-[5px_5px_0px_0px_var(--primary-color)] transition-all">
              <span class="tech-tag text-[9px] text-mono-yellow font-bold block mb-3">PROFILE 0{idx+1}</span>
              <h3 class="font-serif text-base font-bold text-mono-black mb-3">{p.title}</h3>
              <p class="font-sans text-xs text-neutral-600 leading-relaxed">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>

      {/* SECTION 2: PROGRAM LEARNING OUTCOMES */}
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <Award class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Program Learning Outcomes (PLO)' : 'Capaian Pembelajaran Lulusan (CPL)'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {plos.map((p) => (
            <div class="border border-mono-black bg-white p-6 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] flex items-start gap-4">
              <span class="tech-tag text-[9px] bg-mono-black text-white px-2 py-0.5 mt-0.5 shrink-0">{p.code}</span>
              <div>
                <span class="font-serif text-[11px] font-bold text-mono-yellow tracking-wider block mb-1 uppercase">{p.type}</span>
                <p class="font-sans text-xs text-neutral-600 leading-relaxed">{p.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* SECTION 3: CURRICULUM SEMESTERS LIST */}
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <BookOpen class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Course Curriculum Structure (144 Credits)' : 'Struktur Kurikulum & Sebaran Mata Kuliah (144 SKS)'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {semesters.map((s) => (
            <div class="border border-mono-black bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] overflow-hidden">
              <div class="bg-mono-black text-white px-6 py-3.5 flex justify-between items-center border-b border-mono-black">
                <h3 class="font-serif text-base font-bold tracking-wider">
                  {lang === 'en' ? `SEMESTER ${s.sem}` : `SEMESTER ${s.sem}`}
                </h3>
                <span class="tech-tag text-[9px] text-mono-yellow">
                  {s.courses.reduce((acc, c) => acc + c.credits, 0)} {lang === 'en' ? 'CREDITS' : 'SKS'}
                </span>
              </div>
              <div class="divide-y divide-neutral-100 font-sans">
                {s.courses.map((c) => (
                  <div class="px-6 py-4 flex justify-between items-center gap-4 hover:bg-neutral-50 transition-colors">
                    <span class="text-xs font-bold text-mono-black leading-tight">
                      {lang === 'en' ? c.name_en : c.name_id}
                    </span>
                    <span class="tech-tag text-[9px] bg-neutral-100 text-neutral-500 border border-neutral-200 px-2 py-0.5 shrink-0">
                      {c.credits} SKS
                    </span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* SECTION 4: INTERNSHIP FRAMEWORK */}
      <div class="border border-mono-black bg-white p-8 lg:p-12 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-5">
          <Compass class="h-32 w-32 text-mono-yellow" />
        </div>
        <p class="tech-tag text-mono-yellow mb-2">EXPERIENTIAL LEARNING</p>
        <h3 class="font-serif text-2xl font-bold text-mono-black mb-4">{internshipTitle}</h3>
        <p class="font-sans text-xs text-neutral-600 leading-relaxed max-w-4xl mb-6">
          {internshipDesc}
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="tech-tag text-[8px] border border-mono-black/15 bg-neutral-50 text-neutral-600 px-3 py-1 font-bold">STUDY EXCHANGE // PERTUKARAN PELAJAR</span>
          <span class="tech-tag text-[8px] border border-mono-black/15 bg-neutral-50 text-neutral-600 px-3 py-1 font-bold">CERTIFIED INTERNSHIP // MAGANG INDUSTRI MSIB</span>
          <span class="tech-tag text-[8px] border border-mono-black/15 bg-neutral-50 text-neutral-600 px-3 py-1 font-bold">COMMUNITY DEVELOPMENT // KKN TEMATIK</span>
        </div>
      </div>

    </div>
  </section>
</Layout>
