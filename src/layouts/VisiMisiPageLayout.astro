---
import Layout from './Layout.astro';
import { Target, Compass, Flag, ShieldCheck } from 'lucide-react';
import { PRODI_CONFIG } from '../config/prodi.config';
import { getSiteContent } from '../lib/supabase/db';

interface Props {
  lang: 'id' | 'en';
}

const { lang } = Astro.props;

// Fetch database site content
const siteContent = await getSiteContent();
const contentMap = (siteContent || []).reduce((acc, curr) => {
  acc[curr.key] = lang === 'en' ? (curr.value_en || curr.value) : curr.value;
  return acc;
}, {} as Record<string, string>);

const title = lang === 'en'
  ? `Vision & Mission | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`
  : `Visi & Misi | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`;

const heading = lang === 'en' ? 'Vision, Mission & Goals' : 'Visi, Misi & Tujuan Akademik';

const description = lang === 'en'
  ? `The strategic foundation of the ${PRODI_CONFIG.degree} ${PRODI_CONFIG.name.en} program at ${PRODI_CONFIG.universityShort}, integrating modern technology innovation with noble ethical and moral values.`
  : `Landasan strategis penyelenggaraan program studi ${PRODI_CONFIG.degree} ${PRODI_CONFIG.name.id} ${PRODI_CONFIG.universityShort} dalam mengintegrasikan inovasi teknologi modern dengan nilai-nilai moral keislaman.`;

const defaultVision = lang === 'en'
  ? `To become a leading and innovative study program in developing halal food science and technology based on Nusantara food biodiversity through sustainable circular biorefinery systems to produce professional graduates and technopreneurs with Islamic character who are globally competitive and have a broad impact on society.`
  : `Menjadi program studi unggul dan inovatif dalam mengembangkan keilmuan sains dan teknologi pangan halal berbasis keanekaragaman pangan Nusantara melalui sistem biorefinery sirkular berkelanjutan guna menghasilkan lulusan profesional dan teknopreneur berkarakter islami yang berdaya saing global dan berdampak luas bagi masyarakat.`;

const defaultMissions = lang === 'en' ? [
  "Deliver high-quality education and teaching in the field of local food science and technology, food halality, sustainable circular biorefinery systems, and technopreneurship to produce graduates with Islamic character.",
  "Conduct research in innovative food science and technology, focusing on exploration based on Nusantara food biodiversity through sustainable circular biorefinery systems to produce safe, high-quality, and halal food products that impact society.",
  "Implement community service through downstreaming of research results, delivery of scientific knowledge, and application of sustainable circular biorefinery systems to solve food problems and improve community welfare.",
  "Integrate Al-Islam and Kemuhammadiyahan values thoroughly in all education, research, and community service activities."
] : [
  "Menyelenggarakan pendidikan dan pengajaran berkualitas di bidang sains dan teknologi pangan lokal, kehalalan pangan, sistem biorefinery sirkular berkelanjutan, dan teknopreneur dalam menghasilkan lulusan yang berkarakter islami.",
  "Menyelenggarakan penelitian di bidang sains dan teknologi pangan yang inovatif, berfokus pada eksplorasi berbasis keanekaragaman pangan Nusantara melalui sistem biorefinery sirkular berkelanjutan untuk menghasilkan produk pangan yang aman, bermutu, dan halal, serta berdampak pada masyarakat.",
  "Melaksanakan pengabdian kepada masyarakat melalui hilirisasi hasil riset, penyampaian pengetahuan ilmiah, dan penerapan sistem biorefinery sirkular berkelanjutan untuk menyelesaikan permasalahan pangan dan meningkatkan kesejahteraan masyarakat.",
  "Mengintegrasikan nilai-nilai Al-Islam dan Kemuhammadiyahan secara menyeluruh dalam setiap kegiatan pendidikan, penelitian, dan pengabdian kepada masyarakat."
];

const defaultGoals = lang === 'en' ? [
  {
    title: "Food Competency & Professionalism",
    desc: `Produce competent, professional, competitive Food Technology graduates with Islamic character who are able to integrate local food science and technology through sustainable circular biorefinery systems.`
  },
  {
    title: "Local Food Research & Innovation",
    desc: "Produce innovative research in food science and technology engineering oriented towards exploration based on Nusantara food biodiversity through sustainable circular biorefinery systems in developing safe, high-quality, and halal local food innovations."
  },
  {
    title: "Community Solutions & Welfare",
    desc: "Provide real solutions to problems in the fields of food, food safety, and nutrition that impact improving living standards and community welfare through the application of sustainable circular biorefinery systems."
  },
  {
    title: "Islamic Character & Technopreneurship",
    desc: "Produce graduates who have Islamic character, noble morals, and a technopreneurial spirit."
  }
] : [
  {
    title: "Kompetensi & Profesionalisme Pangan",
    desc: `Menghasilkan lulusan sarjana Teknologi Pangan yang kompeten, profesional, berdaya saing, dan berkarakter Islami yang mampu mengintegrasikan sains dan teknologi pangan lokal melalui sistem biorefinery sirkular berkelanjutan.`
  },
  {
    title: "Riset & Inovasi Pangan Lokal",
    desc: "Menghasilkan penelitian inovatif di bidang sains dan rekayasa teknologi pangan yang berorientasi pada eksplorasi berbasis keanekaragaman pangan Nusantara melalui sistem biorefinery sirkular berkelanjutan dalam pengembangan inovasi pangan lokal yang aman, bermutu, dan halal."
  },
  {
    title: "Solusi Kemasyarakatan & Kesejahteraan",
    desc: "Memberikan solusi nyata atas permasalahan di bidang pangan, keamanan pangan, dan gizi yang berdampak pada peningkatan taraf hidup dan kesejahteraan masyarakat melalui penerapan sistem biorefinery sirkular berkelanjutan."
  },
  {
    title: "Karakter Islami & Teknopreneur",
    desc: "Menghasilkan lulusan yang berkarakter Islami, berakhlak karimah, dan berjiwa teknopreneur."
  }
];

// Resolve final database content or defaults
const vision = contentMap['visi_misi_vision'] || defaultVision;

const missions = contentMap['visi_misi_missions']
  ? contentMap['visi_misi_missions'].split('\n').filter(Boolean)
  : defaultMissions;

const goals = contentMap['visi_misi_goals']
  ? contentMap['visi_misi_goals'].split('\n').filter(Boolean).map((line, idx) => {
      const parts = line.split('//');
      const title = parts[0]?.trim();
      const desc = parts[1]?.trim() || (defaultGoals[idx] ? defaultGoals[idx].desc : "");
      return { title, desc };
    })
  : defaultGoals;
---

<Layout title={title} lang={lang}>
  {/* Header Section */}
  <section class="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <p class="tech-tag text-mono-yellow mb-3">DEPARTMENT // STRATEGY</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        {heading}
      </h1>
      <p class="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  {/* Content Section */}
  <section class="py-20 bg-mono-cream min-h-screen">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      
      {/* Vision Card (Neo-brutalist big callout) */}
      <div class="border border-mono-black bg-white p-8 lg:p-12 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] mb-12 relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-5">
          <Compass class="h-40 w-40 text-mono-yellow" />
        </div>
        
        <p class="tech-tag text-mono-yellow mb-3">VISION // VISI UTAMA</p>
        <h2 class="font-serif text-3xl md:text-4xl text-mono-black mb-6 border-b border-dashed border-neutral-200 pb-4">
          {lang === 'en' ? 'Our Strategic Vision' : 'Visi Utama Program Studi'}
        </h2>
        <blockquote id="vision-text" class="font-serif text-xl md:text-2xl lg:text-3xl text-neutral-800 leading-snug italic max-w-4xl">
          "{vision}"
        </blockquote>
      </div>

      {/* Mission & Goals Row */}
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        {/* Mission List */}
        <div class="lg:col-span-6 border border-mono-black bg-white p-8 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
          <p class="tech-tag text-mono-yellow mb-3">MISSION // MISI OPERASIONAL</p>
          <h2 class="font-serif text-2xl text-mono-black mb-8 border-b border-neutral-100 pb-4 flex items-center gap-3">
            <Flag class="h-6 w-6 text-mono-black" />
            <span>{lang === 'en' ? 'Operational Mission' : 'Misi Penyelenggaraan'}</span>
          </h2>
          
          <ul id="mission-list" class="space-y-6">
            {missions.map((m, idx) => (
              <li class="flex gap-4">
                <div class="h-8 w-8 rounded-none bg-mono-black text-white flex items-center justify-center font-serif text-sm font-bold shrink-0">
                  0{idx+1}
                </div>
                <p class="font-sans text-sm text-neutral-700 leading-relaxed pt-0.5">
                  {m}
                </p>
              </li>
            ))}
          </ul>
        </div>

        {/* Goals Grid */}
        <div class="lg:col-span-6 space-y-6">
          <div class="border border-mono-black bg-mono-black text-white p-8 shadow-[4px_4px_0px_0px_var(--primary-color)]">
            <p class="tech-tag text-white/50 mb-2">GOALS // TARGET CAPAIAN</p>
            <h2 class="font-serif text-2xl text-white flex items-center gap-3">
              <Target class="h-6 w-6 text-mono-yellow" />
              <span>{lang === 'en' ? 'Program Educational Goals' : 'Tujuan Program Pendidikan'}</span>
            </h2>
          </div>

          <div id="goals-container" class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {goals.map((g, idx) => (
              <div class="border border-mono-black bg-white p-6 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)]">
                <span class="tech-tag text-[9px] text-mono-yellow font-bold block mb-2">GOAL 0{idx+1}</span>
                <h4 class="font-serif text-base font-bold text-mono-black mb-2">{g.title}</h4>
                <p class="font-sans text-xs text-neutral-600 leading-relaxed">{g.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

  {/* Client-side dynamic update from Supabase */}
  <script define:vars={{
    supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL,
    supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    lang
  }}>
    if (supabaseUrl && supabaseKey && !supabaseUrl.includes('your-project-ref.supabase.co')) {
      const fetchContent = async () => {
        try {
          const res = await fetch(`${supabaseUrl}/rest/v1/site_content`, {
            headers: {
              'apikey': supabaseKey,
              'Authorization': `Bearer ${supabaseKey}`
            }
          });
          if (!res.ok) return;
          const data = await res.json();
          
          const contentMap = {};
          data.forEach(item => {
            contentMap[item.key] = lang === 'en' ? (item.value_en || item.value) : item.value;
          });

          // Update Vision
          const visionVal = contentMap['visi_misi_vision'];
          if (visionVal) {
            const el = document.getElementById('vision-text');
            if (el) el.textContent = `"${visionVal}"`;
          }

          // Update Missions
          const missionsVal = contentMap['visi_misi_missions'];
          if (missionsVal) {
            const listEl = document.getElementById('mission-list');
            if (listEl) {
              const items = missionsVal.split('\n').filter(Boolean);
              listEl.innerHTML = items.map((m, idx) => `
                <li class="flex gap-4">
                  <div class="h-8 w-8 rounded-none bg-mono-black text-white flex items-center justify-center font-serif text-sm font-bold shrink-0">
                    0${idx+1}
                  </div>
                  <p class="font-sans text-sm text-neutral-700 leading-relaxed pt-0.5">
                    ${m}
                  </p>
                </li>
              `).join('');
            }
          }

          // Update Goals
          const goalsVal = contentMap['visi_misi_goals'];
          if (goalsVal) {
            const containerEl = document.getElementById('goals-container');
            if (containerEl) {
              const lines = goalsVal.split('\n').filter(Boolean);
              containerEl.innerHTML = lines.map((line, idx) => {
                const parts = line.split('//');
                const title = parts[0]?.trim() || '';
                const desc = parts[1]?.trim() || '';
                return `
                  <div class="border border-mono-black bg-white p-6 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)]">
                    <span class="tech-tag text-[9px] text-mono-yellow font-bold block mb-2">GOAL 0${idx+1}</span>
                    <h4 class="font-serif text-base font-bold text-mono-black mb-2">${title}</h4>
                    <p class="font-sans text-xs text-neutral-600 leading-relaxed">${desc}</p>
                  </div>
                `;
              }).join('');
            }
          }
        } catch (e) {
          console.error('Failed to sync live vision/mission content:', e);
        }
      };
      fetchContent();
    }
  </script>
</Layout>
