---
import Layout from './Layout.astro';
import { Calendar, MapPin, Eye } from 'lucide-react';
import { PRODI_CONFIG } from '../config/prodi.config';
import { getKegiatanDosen } from '../lib/supabase/db';

interface Props {
  lang: 'id' | 'en';
}

const { lang } = Astro.props;

// ── Fallback static data ────────────────────────────────────────────────────
type ActivityItem = { title: string; date: string; location: string; desc: string; image: string | null };

const fallbackActivities: ActivityItem[] = [
  {
    title: lang === 'en' ? 'International Contemporary Craft Exhibition 2025' : 'Pameran Seni Kriya Kontemporer Internasional 2025',
    date: lang === 'en' ? 'March 12, 2025' : '12 Maret 2025',
    location: 'Kuala Lumpur, Malaysia',
    desc: lang === 'en'
      ? `${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort} faculty presented innovative handwoven art installations combining traditional bamboo split and organic dyes at the Southeast Asian craft symposium.`
      : `Dosen Kriya Tekstil dan Fashion ${PRODI_CONFIG.universityShort} mempresentasikan karya instalasi serat tenun inovatif berbahan bambu dan pewarna alami pada simposium kriya Asia Tenggara.`,
    image: '/assets/kegiatan-d1.png'
  },
  {
    title: lang === 'en' ? 'Organic Ecoprint Workshop for Craft and Fashion MSMEs' : 'Pelatihan Ecoprint Organik bagi Pelaku UMKM Kriya & Fashion',
    date: lang === 'en' ? 'October 18, 2024' : '18 Oktober 2024',
    location: 'Soreang, Bandung',
    desc: lang === 'en'
      ? 'A Public Service initiative providing training on eco-friendly leaf printing on silk fabrics to help local crafters create sustainable commercial products.'
      : 'Pengabdian Kepada Masyarakat (PKM) berupa workshop pembuatan cetak daun (ecoprint) pada media sutra untuk mendorong komersialisasi produk ramah lingkungan.',
    image: '/assets/kegiatan-d2.png'
  },
  {
    title: lang === 'en' ? 'Collaborative Research on Fiber Extraction with BRIN' : 'Kolaborasi Riset Ekstraksi Serat Alam Hayati Bersama BRIN',
    date: lang === 'en' ? 'June 04, 2024' : '04 Juni 2024',
    location: 'BRIN Materials Lab, Serpong',
    desc: lang === 'en'
      ? `A strategic research collaboration by ${PRODI_CONFIG.acronym} lecturers studying extraction of pineapple leaf fibers for premium structural woven fabric applications.`
      : `Kolaborasi riset strategis dosen ${PRODI_CONFIG.acronym} dalam mengekstrak serat daun nanas untuk pengembangan bahan baku benang tenun premium.`,
    image: '/assets/kegiatan-d3.png'
  }
];

// ── Fetch from DB, fall back to static ──────────────────────────────────────
const dbActivities = await getKegiatanDosen();
const activities: ActivityItem[] = (dbActivities && dbActivities.length > 0)
  ? dbActivities.map(a => ({
      title: lang === 'en' ? (a.title_en || a.title) : a.title,
      date: lang === 'en' ? (a.date_text_en || a.date_text) : a.date_text,
      location: a.location,
      desc: lang === 'en' ? (a.desc_en || a.desc) : a.desc,
      image: a.image_url
    }))
  : fallbackActivities;


const title = lang === 'en'
  ? `Faculty Activities | ${PRODI_CONFIG.degree} ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`
  : `Kegiatan Dosen | ${PRODI_CONFIG.degree} ${PRODI_CONFIG.name.id} ${PRODI_CONFIG.universityShort}`;

const heading = lang === 'en' ? 'Faculty Activities & Initiatives' : 'Kegiatan & Pengabdian Dosen';

const description = lang === 'en'
  ? `Documentation of academic endeavors, contemporary design exhibitions, applied community service, and collaborative craft science research conducted by the faculty of ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}.`
  : `Dokumentasi kiprah akademik, pameran desain kontemporer, pengabdian masyarakat terapan, dan riset kriya tekstil kolaboratif yang dilakukan oleh jajaran dosen ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}.`;

const docLabel = 'DOKUMENTASI D-0';
const tagLabel = lang === 'en' ? 'FACULTY / RESEARCH' : 'FAKULTAS / PKM';
const linkLabel = lang === 'en' ? 'MEDIA ARCHIVE' : 'DOKUMENTASI';
---

<Layout title={title} lang={lang}>
  {/* Header Section */}
  <section class="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <p class="tech-tag text-mono-yellow mb-3">GALLERY // FACULTY ACTIVITIES</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        {heading}
      </h1>
      <p class="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  {/* Main Grid */}
  <section class="py-20 bg-mono-cream min-h-screen">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {activities.map((act, idx) => (
          <div key={idx} class="border border-mono-black bg-white hover:shadow-[6px_6px_0px_0px_var(--primary-color)] transition-all duration-300 flex flex-col justify-between">
            {/* Visual Container */}
            <div class="bg-neutral-100 aspect-[4/3] border-b border-mono-black relative overflow-hidden flex items-center justify-center">
              <span class="tech-tag text-mono-black/40 text-[10px]">{docLabel}{idx+1}</span>
            </div>
            
            <div class="p-8 flex-1 flex flex-col justify-between">
              <div>
                <div class="flex flex-wrap gap-4 text-[10px] font-sans font-semibold text-neutral-400 mb-4">
                  <div class="flex items-center gap-1.5">
                    <Calendar class="h-3.5 w-3.5 text-mono-yellow" />
                    <span>{act.date}</span>
                  </div>
                  <div class="flex items-center gap-1.5">
                    <MapPin class="h-3.5 w-3.5 text-mono-yellow" />
                    <span>{act.location}</span>
                  </div>
                </div>
                
                <h3 class="font-serif text-lg font-bold text-mono-black mb-3 leading-snug">
                  {act.title}
                </h3>
                
                <p class="font-sans text-xs text-neutral-600 leading-relaxed mb-6">
                  {act.desc}
                </p>
              </div>

              <div class="pt-4 border-t border-dotted border-neutral-200 flex items-center justify-between">
                <span class="tech-tag text-[9px] text-mono-yellow font-bold">{tagLabel}</span>
                <span class="flex items-center gap-1 font-sans text-[9px] font-bold text-mono-black/60">
                  <Eye class="h-3 w-3" />
                  <span>{linkLabel}</span>
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
