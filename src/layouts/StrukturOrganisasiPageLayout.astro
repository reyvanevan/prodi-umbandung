---
import Layout from './Layout.astro';
import { Shield, Users, Mail, UserPlus } from 'lucide-react';
import { PRODI_CONFIG } from '../config/prodi.config';
import { getSiteContent } from '../lib/supabase/db';

interface Props {
  lang: 'id' | 'en';
}

const { lang } = Astro.props;

// Fetch database site content
const siteContent = await getSiteContent();
const contentMap = (siteContent || []).reduce((acc, curr) => {
  acc[curr.key] = lang === 'en' ? (curr.value_en || curr.value) : curr.value;
  return acc;
}, {} as Record<string, string>);

const title = lang === 'en'
  ? `Organizational Structure | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`
  : `Struktur Organisasi | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`;

const heading = lang === 'en' ? 'Department Governance' : 'Struktur Organisasi & Tata Kelola';

const description = lang === 'en'
  ? `The academic governance body and operational officers directing the ${PRODI_CONFIG.degree} ${PRODI_CONFIG.name.en} program at ${PRODI_CONFIG.universityShort}.`
  : `Jajaran pimpinan akademik dan pelaksana operasional yang mengarahkan program studi ${PRODI_CONFIG.degree} ${PRODI_CONFIG.name.id} ${PRODI_CONFIG.universityShort}.`;

// Structured hierarchy roles from database with fallback
const head = {
  name: contentMap['kaprodi_name'] || PRODI_CONFIG.headOfDepartment.name,
  role: contentMap['kaprodi_title'] || (lang === 'en' ? "Head of Department" : "Ketua Program Studi"),
  desc: lang === 'en'
    ? (contentMap['kaprodi_welcome'] ? contentMap['kaprodi_welcome'].substring(0, 150) + "..." : "Responsible for overall strategic development, curriculum planning, and academic partnerships.")
    : (contentMap['kaprodi_welcome'] ? contentMap['kaprodi_welcome'].substring(0, 150) + "..." : "Penanggung jawab utama pengembangan strategis, penjaminan mutu kurikulum, dan kemitraan eksternal prodi."),
  email: PRODI_CONFIG.contact.email,
  photo: contentMap['kaprodi_photo_url'] || "/assets/kaprodi.png"
};

const officers = [
  {
    name: contentMap['gov_sec_name'] || "Vritta Amroini Wahyudi, S.Si., M.Si.",
    role: contentMap['gov_sec_role'] || (lang === 'en' ? "Secretary of Department" : "Sekretaris Program Studi"),
    desc: lang === 'en' ? "Directs student administration, lecture schedules, exam coordination, and student records." : "Mengelola administrasi mahasiswa, koordinasi jadwal kuliah, persiapan ujian, dan rekam akademik.",
    email: contentMap['gov_sec_email'] || "vritta.aw@umbandung.ac.id",
    photo: contentMap['gov_sec_photo'] || "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=300&auto=format&fit=crop"
  },
  {
    name: contentMap['gov_lab_name'] || "Hanif Alamudin Manshur, S.Gz., M.Si.",
    role: contentMap['gov_lab_role'] || (lang === 'en' ? "Head of Computing Laboratories" : "Kepala Laboratorium Komputasi"),
    desc: lang === 'en' ? "Manages servers, software licensing, studio resources, network infrastructures, and laboratory assistants." : "Mengelola workstation, lisensi perangkat lunak, infrastruktur jaringan studio, serta koordinasi asisten lab.",
    email: contentMap['gov_lab_email'] || "hanif.am@umbandung.ac.id",
    photo: contentMap['gov_lab_photo'] || "https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=300&auto=format&fit=crop"
  },
  {
    name: contentMap['gov_upm_name'] || "Indra Hidayat, S.Ds., M.Sn.",
    role: contentMap['gov_upm_role'] || (lang === 'en' ? "Quality Assurance Unit" : "Unit Penjaminan Mutu"),
    desc: lang === 'en' ? "Monitors educational standards, evaluates learning quality, and oversees academic audits." : "Memantau standar pendidikan, mengevaluasi mutu pembelajaran, dan mengawasi audit mutu akademik.",
    email: contentMap['gov_upm_email'] || "indra.h@umbandung.ac.id",
    photo: contentMap['gov_upm_photo'] || "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=300&auto=format&fit=crop"
  }
];

const boards = lang === 'en' ? [
  {
    title: "Academic Advisory Council",
    members: ["Prof. Dr. Ir. Noor Harini, M.S.", "Dr. H. Ahmad Dahlan, M.T."],
    desc: "Provides advisory supervision on curriculum alignment, learning resources quality, and accreditation guidelines."
  },
  {
    title: "Student Association Representative (HIMA)",
    members: ["Daffa Zaidan (Chairman of HIMATEPA)", "Naila Putri (Secretary of HIMATEPA)"],
    desc: "Coordinates student community affairs, co-curricular food expos, food safety workshops, and academic feedback channels."
  }
] : [
  {
    title: "Dewan Penasehat Akademik",
    members: ["Prof. Dr. Ir. Noor Harini, M.S.", "Dr. H. Ahmad Dahlan, M.T."],
    desc: "Memberikan arahan strategis penyesuaian kurikulum, pengawasan penjaminan mutu pengajaran, serta persiapan akreditasi."
  },
  {
    title: "Himpunan Mahasiswa (HIMATEPA)",
    members: ["Daffa Zaidan (Ketua Himpunan)", "Naila Putri (Sekretaris Himpunan)"],
    desc: "Mengkoordinasikan kegiatan ekstrakurikuler mahasiswa, pameran pangan, pengabdian masyarakat sanitasi pangan, dan aspirasi kemahasiswaan."
  }
];
---

<Layout title={title} lang={lang}>
  {/* Header Section */}
  <section class="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <p class="tech-tag text-mono-yellow mb-3">GOVERNANCE // ORGANIGRAM</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        {heading}
      </h1>
      <p class="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  {/* Governance Tree Structure */}
  <section class="py-20 bg-mono-cream min-h-screen">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      
      {/* 1. Level 1: Head of Department */}
      <div class="flex justify-center mb-16">
        <div class="max-w-2xl w-full border border-mono-black bg-white shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] grid grid-cols-1 md:grid-cols-12 overflow-hidden">
          {/* Avatar side */}
          <div class="md:col-span-4 bg-neutral-100 aspect-square md:aspect-auto relative overflow-hidden min-h-[200px]">
            <img 
              src={head.photo} 
              alt={head.name} 
              className="absolute inset-0 w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
            />
          </div>
          {/* Content side */}
          <div class="md:col-span-8 p-8 flex flex-col justify-between">
            <div>
              <span class="tech-tag bg-mono-black text-white px-2 py-0.5 text-[9px] tracking-widest inline-block mb-3">
                {head.role.toUpperCase()}
              </span>
              <h3 class="font-serif text-2xl font-bold text-mono-black mb-1">{head.name}</h3>
              <p class="font-sans text-xs text-neutral-600 leading-relaxed mb-6">
                {head.desc}
              </p>
            </div>
            
            <div class="border-t border-dotted border-neutral-200 pt-4 flex items-center gap-2">
              <Mail className="h-4 w-4 text-mono-yellow shrink-0" />
              <a href={`mailto:${head.email}`} class="font-sans text-xs text-mono-black hover:underline truncate">
                {head.email}
              </a>
            </div>
          </div>
        </div>
      </div>

      {/* Decorative vertical line connector */}
      <div class="hidden md:flex justify-center mb-6">
        <div class="w-0.5 h-12 bg-mono-black/25 border-dashed border-l-2"></div>
      </div>

      {/* 2. Level 2: Officers (Secretary, Lab Head, & UPM) */}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
        {officers.map((o) => (
          <div class="border border-mono-black bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] grid grid-cols-1 sm:grid-cols-12 overflow-hidden">
            {/* Photo */}
            <div class="sm:col-span-4 bg-neutral-100 aspect-square sm:aspect-auto relative overflow-hidden min-h-[160px]">
              <img 
                src={o.photo} 
                alt={o.name} 
                className="absolute inset-0 w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
              />
            </div>
            {/* Bio */}
            <div class="sm:col-span-8 p-6 flex flex-col justify-between">
              <div>
                <span class="tech-tag text-mono-yellow text-[9px] tracking-wide block mb-2">{o.role.toUpperCase()}</span>
                <h4 class="font-serif text-lg font-bold text-mono-black mb-2">{o.name}</h4>
                <p class="font-sans text-xs text-neutral-500 leading-relaxed mb-4">
                  {o.desc}
                </p>
              </div>
              <div class="border-t border-dashed border-neutral-200 pt-3 flex items-center gap-2">
                <Mail className="h-3 w-3 text-mono-black/55 shrink-0" />
                <a href={`mailto:${o.email}`} class="font-sans text-[11px] text-mono-black hover:underline truncate">
                  {o.email}
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* 3. Advisory & Student Boards */}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {boards.map((b) => (
          <div class="border border-mono-black bg-white p-8 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] flex flex-col justify-between">
            <div>
              <p class="tech-tag text-mono-black/40 text-[9px] tracking-widest mb-2">BOARD // COMMITTEE</p>
              <h3 class="font-serif text-xl font-bold text-mono-black mb-4 pb-2 border-b border-neutral-100">
                {b.title}
              </h3>
              <p class="font-sans text-xs text-neutral-600 leading-relaxed mb-6">
                {b.desc}
              </p>
            </div>
            
            <div class="bg-neutral-50 border border-dashed border-neutral-200 p-4 space-y-2">
              {b.members.map((m) => (
                <div class="flex items-center gap-2.5">
                  <div class="h-1.5 w-1.5 rounded-full bg-mono-yellow shrink-0" />
                  <span class="font-serif text-xs font-bold text-mono-black">{m}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
</Layout>
