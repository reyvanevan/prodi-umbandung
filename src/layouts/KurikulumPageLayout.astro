---
import Layout from './Layout.astro';
import { BookOpen, GraduationCap, Award, Compass } from 'lucide-react';
import { PRODI_CONFIG } from '../config/prodi.config';
import { getSiteContent, getKurikulumCourses, getKurikulumPlos, getKurikulumProfiles } from '../lib/supabase/db';

interface Props {
  lang: 'id' | 'en';
}

const { lang } = Astro.props;

// Fetch database site content
const siteContent = await getSiteContent();
const contentMap = (siteContent || []).reduce((acc, curr) => {
  acc[curr.key] = lang === 'en' ? (curr.value_en || curr.value) : curr.value;
  return acc;
}, {} as Record<string, string>);

const title = lang === 'en'
  ? `Curriculum & Academic Structure | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`
  : `Kurikulum & Akademik | ${PRODI_CONFIG.acronym} ${PRODI_CONFIG.universityShort}`;

const heading = lang === 'en' ? 'Academic Program Curriculum' : 'Kurikulum & Capaian Pembelajaran';

const defaultDescription = lang === 'en'
  ? `Explore our structured, adaptive curriculum focusing on creative textile techniques, fashion styling, circular sustainability, and entrepreneurship.`
  : `Pelajari struktur kurikulum adaptif kami yang dirancang untuk membekali mahasiswa dengan keahlian teknik tekstil kreatif, desain mode, keberlanjutan sirkular, dan wirausaha kreatif.`;

const description = contentMap['kurikulum_description'] || defaultDescription;

// 1. Graduate Profiles (Fallbacks)
const fallbackProfiles = lang === 'en' ? [
  {
    title: "Fashion / Textile Designer",
    desc: "Professionals who design textile patterns, fabrics, and ready-to-wear fashion collections for industries and independent brands."
  },
  {
    title: "Contemporary Craft Artist & Maker",
    desc: "Independent artists creating fiber art, installations, and high-value handmade design objects for exhibitions and galleries."
  },
  {
    title: "Fashion Stylist & Visual Merchandiser",
    desc: "Experts curating visual identities, directing photo shoots, styling media content, and designing boutique store displays."
  },
  {
    title: "Creativepreneur (Craft & Fashion)",
    desc: "Entrepreneurs establishing sustainable fashion labels, handicraft studios, or textile craft businesses based on local culture."
  }
] : [
  {
    title: "Fashion / Textile Designer",
    desc: "Profesional yang merancang motif tekstil, material kain, dan koleksi busana siap pakai untuk industri maupun brand mandiri."
  },
  {
    title: "Contemporary Craft Artist & Maker",
    desc: "Seniman kriya mandiri yang menciptakan karya seni serat, instalasi, dan produk kerajinan bernilai seni tinggi untuk galeri dan pameran."
  },
  {
    title: "Fashion Stylist & Visual Merchandiser",
    desc: "Ahli tata gaya busana untuk media/photoshoot, pengarah konsep visual brand, serta perancang display butik retail fashion."
  },
  {
    title: "Creativepreneur (Kriya & Fashion)",
    desc: "Wirausahawan kreatif yang membangun brand fashion ramah lingkungan, studio kriya, atau bisnis kreatif berbasis pemberdayaan lokal."
  }
];

const dbProfiles = await getKurikulumProfiles();
const profiles = (dbProfiles && dbProfiles.length > 0)
  ? dbProfiles.map(p => ({
      title: lang === 'en' ? (p.title_en || p.title) : p.title,
      desc: lang === 'en' ? (p.desc_en || p.desc) : p.desc
    }))
  : fallbackProfiles;

// 2. Program Learning Outcomes (PLO/CPL) (Fallbacks)
const fallbackPlos = lang === 'en' ? [
  { code: "CPL-01", type: "Islamic Values & Ethics", text: "Incorporate Islamic values, professional design ethics, and sustainability principles in community and creative industries." },
  { code: "CPL-02", type: "Craft & Fashion Theory", text: "Master concepts of art history, color theory, textile fibers, and garment construction techniques deeply." },
  { code: "CPL-03", type: "Design & Technical Skills", text: "Design innovative textile crafts (surface and structure) and fashion collections based on local culture and eco-friendly design." },
  { code: "CPL-04", type: "Creativepreneurship", text: "Identify market opportunities and build independent cultural-tech creative business brands in craft/fashion." }
] : [
  { code: "CPL-01", type: "Nilai Islam & Etika", text: "Menginternalisasikan nilai-nilai Keislaman, etika profesi desain, dan prinsip keberlanjutan dalam kehidupan bermasyarakat dan industri kreatif." },
  { code: "CPL-02", type: "Teori Kriya & Mode", text: "Menguasai konsep sejarah kriya, teori warna, trend forecasting, serat tekstil, serta teknik konstruksi sandang secara mendalam." },
  { code: "CPL-03", type: "Keterampilan Desain", text: "Mampu merancang karya kriya tekstil (surface & structure) serta koleksi busana yang inovatif berbasis kearifan lokal dan ramah lingkungan." },
  { code: "CPL-04", type: "Creativepreneurship", text: "Mampu mengidentifikasi peluang pasar dan membangun bisnis kreatif mandiri (brand kriya/fashion) berbasis technopreneurship budaya." }
];

const dbPlos = await getKurikulumPlos();
const plos = (dbPlos && dbPlos.length > 0)
  ? dbPlos.map(p => ({
      code: p.code,
      type: lang === 'en' ? (p.type_en || p.type) : p.type,
      text: lang === 'en' ? (p.text_en || p.text) : p.text
    }))
  : fallbackPlos;

// 3. Curriculum Semesters Data (Fallbacks)
const fallbackSemesters = [
  {
    sem: "I",
    courses: [
      { name_en: "Introduction to Art & Design", name_id: "Pengantar Seni & Desain", credits: 3 },
      { name_en: "Drawing Fundamentals", name_id: "Dasar Rupa & Menggambar", credits: 3 },
      { name_en: "Textile Fibers & Materials", name_id: "Serat & Material Tekstil", credits: 3 },
      { name_en: "Islamic Studies I", name_id: "Studi Islam I", credits: 2 },
      { name_en: "English Language I", name_id: "Bahasa Inggris I", credits: 2 },
      { name_en: "Color Theory & Practice", name_id: "Teori & Praktik Warna", credits: 3 },
      { name_en: "Introduction to Creativepreneurship", name_id: "Pengantar Creativepreneurship", credits: 2 }
    ]
  },
  {
    sem: "II",
    courses: [
      { name_en: "Surface Design I (Batik)", name_id: "Surface Design I (Batik)", credits: 3 },
      { name_en: "Structure Design I (Weaving)", name_id: "Structure Design I (Tenun)", credits: 3 },
      { name_en: "Fashion Illustration", name_id: "Ilustrasi Mode", credits: 3 },
      { name_en: "History of Nusantara Art & Craft", name_id: "Sejarah Seni & Kriya Nusantara", credits: 3 },
      { name_en: "Islamic Studies II", name_id: "Studi Islam II", credits: 2 },
      { name_en: "Civic Education", name_id: "Pendidikan Kewarganegaraan", credits: 2 },
      { name_en: "Textile Dyeing Technology", name_id: "Teknologi Pewarnaan Tekstil", credits: 3 }
    ]
  },
  {
    sem: "III",
    courses: [
      { name_en: "Surface Design II (Ecoprint & Dye)", name_id: "Surface Design II (Ecoprint & Celup)", credits: 3 },
      { name_en: "Structure Design II (Knit & Tapestry)", name_id: "Structure Design II (Rajut & Tapestri)", credits: 3 },
      { name_en: "Pattern Drafting & Sewing", name_id: "Pola & Teknik Menjahit", credits: 3 },
      { name_en: "Textile Motif Development", name_id: "Pengembangan Motif Tekstil", credits: 3 },
      { name_en: "Fashion History & Trends", name_id: "Sejarah & Tren Fashion", credits: 3 },
      { name_en: "Islamic Studies III", name_id: "Studi Islam III", credits: 2 }
    ]
  },
  {
    sem: "IV",
    courses: [
      { name_en: "Draping & Fashion Construction", name_id: "Draping & Konstruksi Mode", credits: 3 },
      { name_en: "Digital Textile & Motif Design", name_id: "Desain Motif & Tekstil Digital", credits: 4 },
      { name_en: "Traditional Textile Crafts", name_id: "Kriya Tekstil Tradisional", credits: 3 },
      { name_en: "Creative Industry Business", name_id: "Bisnis Industri Kreatif", credits: 2 },
      { name_en: "Sustainable Fashion & Craft", name_id: "Fashion & Kriya Berkelanjutan", credits: 3 },
      { name_en: "Research Methods for Design", name_id: "Metode Penelitian Desain", credits: 3 }
    ]
  },
  {
    sem: "V",
    courses: [
      { name_en: "Contemporary Craft Art Study", name_id: "Kajian Seni Kriya Kontemporer", credits: 3 },
      { name_en: "Visual Merchandising & Display", name_id: "Visual Merchandising & Display", credits: 3 },
      { name_en: "Textile Product Development", name_id: "Pengembangan Produk Tekstil", credits: 3 },
      { name_en: "Fashion Styling & Photoshoot", name_id: "Fashion Styling & Photoshoot", credits: 3 },
      { name_en: "Elective Course I (Embroidery)", name_id: "Mata Kuliah Pilihan I (Sulam)", credits: 3 },
      { name_en: "Islamic Studies IV", name_id: "Studi Islam IV", credits: 2 }
    ]
  },
  {
    sem: "VI",
    courses: [
      { name_en: "Art & Design Research Seminar", name_id: "Seminar Penelitian Seni & Desain", credits: 2 },
      { name_en: "Creative Portfolio & Branding", name_id: "Portofolio Kreatif & Branding", credits: 3 },
      { name_en: "Creative Industry Internship (MBKM)", name_id: "Magang Industri Kreatif (MBKM)", credits: 6 },
      { name_en: "Elective Course II (Macrame)", name_id: "Mata Kuliah Pilihan II (Makrame)", credits: 3 },
      { name_en: "Elective Course III (Lace)", name_id: "Mata Kuliah Pilihan III (Renda)", credits: 3 }
    ]
  },
  {
    sem: "VII",
    courses: [
      { name_en: "Brand Incubation & Startup", name_id: "Inkubasi Brand & Startup", credits: 2 },
      { name_en: "Design Professional Ethics", name_id: "Etika Profesi Desain", credits: 2 },
      { name_en: "Final Project Proposal", name_id: "Proposal Tugas Akhir", credits: 2 },
      { name_en: "Elective Course IV (Leather Craft)", name_id: "Mata Kuliah Pilihan IV (Kriya Kulit)", credits: 3 },
      { name_en: "Elective Course V (Jewelry Design)", name_id: "Mata Kuliah Pilihan V (Desain Perhiasan)", credits: 3 }
    ]
  },
  {
    sem: "VIII",
    courses: [
      { name_en: "Final Design Exhibition & Thesis", name_id: "Sidang Karya & Skripsi Tugas Akhir", credits: 6 }
    ]
  }
];

const dbCourses = await getKurikulumCourses();
let semesters = fallbackSemesters;
if (dbCourses && dbCourses.length > 0) {
  const semOrder = ["I", "II", "III", "IV", "V", "VI", "VII", "VIII"];
  const grouped: Record<string, typeof dbCourses> = {};
  semOrder.forEach(s => {
    grouped[s] = [];
  });
  
  dbCourses.forEach(c => {
    const s = c.semester;
    if (grouped[s]) {
      grouped[s].push(c);
    } else {
      grouped[s] = [c];
    }
  });
  
  semesters = semOrder.map(s => {
    const sortedCourses = (grouped[s] || []).sort((a, b) => a.sort_order - b.sort_order);
    return {
      sem: s,
      courses: sortedCourses.map(c => ({
        id: c.id,
        name_en: c.name_en || c.name,
        name_id: c.name,
        credits: c.credits,
        rps_url: c.rps_url || null
      }))
    };
  });
}

const internshipTitle = lang === 'en' ? 'MBKM & Internship Framework' : 'Skema Magang Industri & MBKM';
const defaultInternshipDesc = lang === 'en'
  ? "Our students are eligible to convert real-world industrial experiences into up to 20 academic credits under the Kemendikbud MBKM schema, collaborating with national fashion houses, textile manufacturers, craft studios, and contemporary art galleries."
  : "Mahasiswa kami difasilitasi untuk mengkonversikan pengalaman kerja lapangan / magang industri riil hingga 20 SKS akademik di bawah skema MBKM Kemendikbud, bermitra dengan butik desainer nasional, industri tekstil (PT Kahatex), Rumah Batik Komar, dan galeri seni kontemporer.";
const internshipDesc = contentMap['kurikulum_internship_desc'] || defaultInternshipDesc;
---

<Layout title={title} lang={lang}>
  {/* Header Section */}
  <section class="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <p class="tech-tag text-mono-yellow mb-3">ACADEMICS // CURRICULUM</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        {heading}
      </h1>
      <p class="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  {/* Main Content Area */}
  <section class="py-20 bg-mono-cream min-h-screen space-y-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      
      {/* SECTION 1: GRADUATE PROFILES */}
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <GraduationCap class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Graduate Career Profiles' : 'Profil Lulusan Utama'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {profiles.map((p, idx) => (
            <div class="border border-mono-black bg-white p-6 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] hover:shadow-[5px_5px_0px_0px_var(--primary-color)] transition-all">
              <span class="tech-tag text-[9px] text-mono-yellow font-bold block mb-3">PROFILE 0{idx+1}</span>
              <h3 class="font-serif text-base font-bold text-mono-black mb-3">{p.title}</h3>
              <p class="font-sans text-xs text-neutral-600 leading-relaxed">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>

      {/* SECTION 2: PROGRAM LEARNING OUTCOMES */}
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <Award class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Program Learning Outcomes (PLO)' : 'Capaian Pembelajaran Lulusan (CPL)'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {plos.map((p) => (
            <div class="border border-mono-black bg-white p-6 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] flex items-start gap-4">
              <span class="tech-tag text-[9px] bg-mono-black text-white px-2 py-0.5 mt-0.5 shrink-0">{p.code}</span>
              <div>
                <span class="font-serif text-[11px] font-bold text-mono-yellow tracking-wider block mb-1 uppercase">{p.type}</span>
                <p class="font-sans text-xs text-neutral-600 leading-relaxed">{p.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* SECTION 3: CURRICULUM SEMESTERS LIST */}
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <BookOpen class="h-6 w-6 text-mono-yellow" />
          <h2 class="font-serif text-2xl md:text-3xl text-mono-black font-bold">
            {lang === 'en' ? 'Course Curriculum Structure (144 Credits)' : 'Struktur Kurikulum & Sebaran Mata Kuliah (144 SKS)'}
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {semesters.map((s) => (
            <div class="border border-mono-black bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] overflow-hidden">
              <div class="bg-mono-black text-white px-6 py-3.5 flex justify-between items-center border-b border-mono-black">
                <h3 class="font-serif text-base font-bold tracking-wider">
                  {lang === 'en' ? `SEMESTER ${s.sem}` : `SEMESTER ${s.sem}`}
                </h3>
                <span class="tech-tag text-[9px] text-mono-yellow">
                  {s.courses.reduce((acc, c) => acc + c.credits, 0)} {lang === 'en' ? 'CREDITS' : 'SKS'}
                </span>
              </div>
              <div class="divide-y divide-neutral-100 font-sans">
                {s.courses.map((c) => (
                  <div class="px-6 py-4 flex justify-between items-center gap-4 hover:bg-neutral-50 transition-colors">
                    <div class="flex flex-col gap-1">
                      <span class="text-xs font-bold text-mono-black leading-tight">
                        {lang === 'en' ? c.name_en : c.name_id}
                      </span>
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                      <div class="rps-btn-container" data-course-id={c.id}>
                        {c.rps_url && (
                          <a 
                            href={c.rps_url} 
                            target="_blank" 
                            rel="noopener noreferrer" 
                            class="tech-tag text-[9px] bg-mono-black text-white hover:bg-transparent hover:text-mono-black border border-mono-black px-2 py-0.5 shrink-0 transition-colors inline-flex items-center gap-1 no-underline"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                            <span>RPS</span>
                          </a>
                        )}
                      </div>
                      <span class="tech-tag text-[9px] bg-neutral-100 text-neutral-500 border border-neutral-200 px-2 py-0.5 shrink-0">
                        {c.credits} SKS
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* SECTION 4: INTERNSHIP FRAMEWORK */}
      <div class="border border-mono-black bg-white p-8 lg:p-12 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-5">
          <Compass class="h-32 w-32 text-mono-yellow" />
        </div>
        <p class="tech-tag text-mono-yellow mb-2">EXPERIENTIAL LEARNING</p>
        <h3 class="font-serif text-2xl font-bold text-mono-black mb-4">{internshipTitle}</h3>
        <p class="font-sans text-xs text-neutral-600 leading-relaxed max-w-4xl mb-6">
          {internshipDesc}
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="tech-tag text-[8px] border border-mono-black/15 bg-neutral-50 text-neutral-600 px-3 py-1 font-bold">STUDY EXCHANGE // PERTUKARAN PELAJAR</span>
          <span class="tech-tag text-[8px] border border-mono-black/15 bg-neutral-50 text-neutral-600 px-3 py-1 font-bold">CERTIFIED INTERNSHIP // MAGANG INDUSTRI MSIB</span>
          <span class="tech-tag text-[8px] border border-mono-black/15 bg-neutral-50 text-neutral-600 px-3 py-1 font-bold">COMMUNITY DEVELOPMENT // KKN TEMATIK</span>
        </div>
      </div>

    </div>
  </section>

  <script is:inline define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
    if (supabaseUrl && supabaseKey) {
      fetch(`${supabaseUrl}/rest/v1/kurikulum_courses?select=id,rps_url`, {
        headers: {
          'apikey': supabaseKey,
          'Authorization': `Bearer ${supabaseKey}`
        }
      })
      .then(res => res.json())
      .then(data => {
        if (Array.isArray(data)) {
          data.forEach(item => {
            const container = document.querySelector(`.rps-btn-container[data-course-id="${item.id}"]`);
            if (container) {
              if (item.rps_url) {
                container.innerHTML = `
                  <a 
                    href="${item.rps_url}" 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="tech-tag text-[9px] bg-mono-black text-white hover:bg-transparent hover:text-mono-black border border-mono-black px-2 py-0.5 shrink-0 transition-colors inline-flex items-center gap-1 no-underline"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                    <span>RPS</span>
                  </a>
                `;
              } else {
                container.innerHTML = '';
              }
            }
          });
        }
      })
      .catch(err => console.error('Error syncing RPS links dynamically:', err));
    }
  </script>
</Layout>
