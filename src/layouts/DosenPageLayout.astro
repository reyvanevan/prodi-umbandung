---
import Layout from './Layout.astro';
import { DosenListSection } from '../sections/DosenListSection';
import { PRODI_CONFIG } from '../config/prodi.config';

interface Props {
  lang: 'id' | 'en';
}

const { lang } = Astro.props;

const title = lang === 'en' 
  ? `Lecturer, Staff, & Technician Profiles | ${PRODI_CONFIG.degree} ${PRODI_CONFIG.name.en} ${PRODI_CONFIG.universityShort}`
  : `Profil Dosen, Karyawan, & Laboran | ${PRODI_CONFIG.degree} ${PRODI_CONFIG.name.id} ${PRODI_CONFIG.universityShort}`;

const heading = lang === 'en' ? 'Lecturer, Staff, & Technician Profiles' : 'Profil Dosen, Karyawan, & Laboran';

const description = lang === 'en'
  ? `List of teaching faculty, laboratory technicians, and academic staff in the ${PRODI_CONFIG.degree} ${PRODI_CONFIG.name.en} Program, ${PRODI_CONFIG.university} with professional expertise in food science, food processing technology, food microbiology, and food safety & analysis.`
  : `Daftar dosen pengajar, laboran, dan staf akademik Program Studi ${PRODI_CONFIG.degree} ${PRODI_CONFIG.name.id} ${PRODI_CONFIG.university} yang memiliki keahlian profesional di bidang ilmu pangan, teknologi pengolahan pangan, mikrobiologi pangan, serta keamanan dan analisis pangan.`;
---

<Layout title={title} lang={lang}>
  {/* Header Section */}
  <section class="relative bg-mono-black text-white pt-36 pb-20 border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <p class="tech-tag text-mono-yellow mb-3">FACULTY // PROFILES & STAFF</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl tracking-wide leading-none">
        {heading}
      </h1>
      <p class="font-sans text-sm text-white/60 max-w-2xl mt-4 leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  {/* Main Grid Section */}
  <section class="py-20 bg-mono-cream min-h-screen">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <DosenListSection lang={lang} client:load />
    </div>
  </section>
</Layout>
